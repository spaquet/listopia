<!-- app/views/chat/_unified_chat.html.erb
     Unified chat partial that adapts to different contexts (dashboard, floating, etc.)
     Handles both initial render and Turbo Stream updates
-->

<!-- Subscribe to chat updates via Turbo Streams -->
<%= turbo_stream_from "chat_#{chat.id}" %>

<div id="unified-chat"
     data-controller="unified-chat chat-navigation chat-mentions"
     data-unified-chat-location-value="<%= context.location %>"
     data-unified-chat-chat-id-value="<%= chat.id %>"
     data-chat-navigation-chat-id-value="<%= chat.id %>"
     data-chat-mentions-chat-id-value="<%= chat.id %>"
     class="<%= context.ui_config[:position] %> <% if context.in_location?(:floating) %>shadow-pop rounded-md border border-rule<% end %>">

  <!-- Chat Container -->
  <div class="flex flex-col <%= context.ui_config[:chat_height] %> bg-surface <% unless context.in_location?(:floating) %>rounded-md border border-rule shadow-card<% end %>">

    <!-- Chat Header -->
    <div class="flex items-center justify-between px-3 py-2 border-b border-rule bg-surface">
      <div class="flex items-center gap-2">
        <h3 class="font-medium text-sm text-ink">
          <% if context.focused_resource.present? %>
            <%= context.focused_resource_name %>
          <% else %>
            Chat
          <% end %>
        </h3>
      </div>

      <div class="flex items-center gap-2">
        <% if context.ui_config[:show_new_chat_button] %>
          <%= button_to chats_path,
                        method: :post,
                        form_class: "inline",
                        class: "text-ink-muted hover:text-accent transition-colors",
                        title: "New Chat" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
          <% end %>
        <% end %>

        <% if context.in_location?(:floating) %>
          <button data-action="floating-chat#collapse"
                  type="button"
                  class="w-7 h-7 flex items-center justify-center text-ink-muted hover:text-accent hover:bg-surface-raised rounded-sm transition-all duration-fast"
                  title="Collapse chat"
                  aria-label="Collapse chat">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        <% end %>
      </div>
    </div>

    <!-- Messages Container -->
    <div id="chat-messages-<%= chat.id %>"
         class="flex-1 overflow-y-auto p-3 space-y-3 bg-surface"
         data-unified-chat-target="messagesContainer">

      <% if message_history.blank? %>
        <!-- Empty State with Suggestions -->
        <div class="flex flex-col items-center justify-center h-full gap-3 text-center">
          <h2 class="text-sm font-medium text-ink">Start a conversation</h2>
          <p class="text-ink-muted text-xs max-w-xs">
            <% if context.focused_resource.present? %>
              Ask anything about <%= context.focused_resource_name %>, or use commands.
            <% else %>
              Try /search, /browse, or start chatting.
            <% end %>
          </p>

          <!-- Available Commands -->
          <div class="mt-3 space-y-1 w-full">
            <div class="space-y-1">
              <% context.suggestions.each do |suggestion| %>
                <button class="w-full text-left px-2 py-1.5 rounded-sm hover:bg-surface-raised transition-colors text-xs duration-fast"
                        data-action="unified-chat#insertCommand"
                        data-command="<%= suggestion[:command] %>">
                  <span class="font-mono text-accent"><%= suggestion[:command] %></span>
                  <span class="text-ink-muted ml-2"><%= suggestion[:description] %></span>
                </button>
              <% end %>
            </div>

            <!-- Context Info -->
            <% if context.focused_resource.present? %>
              <div class="mt-2 pt-2 border-t border-rule">
                <p class="text-xs text-ink-muted mb-1">Context: <strong><%= context.focused_resource_name %></strong></p>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <!-- Message History -->
        <% message_history.each do |message| %>
          <%= render "shared/chat_message", message: message, chat_context: context %>
        <% end %>
      <% end %>
    </div>

    <!-- Input Area -->
    <div class="border-t border-rule p-3 bg-surface relative">
      <%= form_with url: create_message_chat_path(chat),
                     method: :post,
                     local: false,
                     class: "flex gap-2 relative",
                     data: {
                       unified_chat_target: "messageForm",
                       turbo_confirm: nil
                     } do |f| %>
        <!-- Message Input -->
        <%= f.text_field "message[content]",
                         id: "message-input-#{chat.id}",
                         placeholder: "Type / for commands...",
                         class: "form-input flex-1 text-sm",
                         data: {
                           unified_chat_target: "messageInput",
                           chat_mentions_target: "input",
                           action: "input->chat-mentions#handleInput keydown->chat-mentions#handleKeyDown"
                         },
                         autocomplete: "off" %>

        <!-- Submit Button -->
        <button type="submit"
                class="btn btn-primary p-2 flex items-center justify-center"
                data-unified-chat-target="submitButton"
                title="Send message">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
          </svg>
        </button>
      <% end %>
    </div>
  </div>
</div>
