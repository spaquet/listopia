<%= form_with model: [@agent, @resource], local: true, class: "space-y-3" do |f| %>
  <% if @resource.errors.any? %>
    <div class="alert alert-danger">
      <div class="alert-icon">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="alert-content">
        <p class="alert-message"><%= pluralize(@resource.errors.count, "error") %></p>
        <ul class="mt-1 text-sm list-disc list-inside">
          <% @resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :resource_type, class: "form-label" %>
    <%= f.select :resource_type, AiAgentResource::RESOURCE_TYPES.map { |t| [t.titleize, t] }, {}, class: "form-input" %>
  </div>

  <div>
    <%= f.label :permission, class: "form-label" %>
    <%= f.select :permission, AiAgentResource.permissions.keys.map { |k| [k.titleize.gsub("_", " "), k] }, {}, class: "form-input" %>
  </div>

  <div>
    <%= f.label :description, class: "form-label" %>
    <%= f.text_field :description, placeholder: "Optional description", class: "form-input" %>
  </div>

  <div>
    <%= f.label :resource_identifier, "Resource ID", class: "form-label" %>
    <%= f.text_field :resource_identifier, placeholder: "Optional: specific resource UUID or identifier", class: "form-input" %>
    <p class="text-xs text-ink-muted mt-1">Leave blank to allow access to all instances of this resource type</p>
  </div>

  <div class="flex gap-2 pt-2">
    <%= f.submit @resource.new_record? ? "Add Resource" : "Update Resource", class: "btn btn-primary btn-sm" %>
    <%= link_to "Cancel", ai_agent_path(@agent), class: "btn btn-secondary btn-sm" %>
  </div>
<% end %>
