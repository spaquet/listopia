<%= form_with model: [@agent, @resource], local: true, class: "space-y-3" do |f| %>
  <% if @resource.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-2">
      <p class="text-xs font-semibold text-red-900"><%= pluralize(@resource.errors.count, "error") %></p>
      <ul class="text-xs text-red-700 list-disc list-inside">
        <% @resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :resource_type, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.select :resource_type, AiAgentResource::RESOURCE_TYPES.map { |t| [t.titleize, t] }, {}, class: "w-full border border-gray-300 rounded p-2 text-sm" %>
  </div>

  <div>
    <%= f.label :permission, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.select :permission, AiAgentResource.permissions.keys.map { |k| [k.titleize.gsub("_", " "), k] }, {}, class: "w-full border border-gray-300 rounded p-2 text-sm" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :description, placeholder: "Optional description", class: "w-full border border-gray-300 rounded p-2 text-sm" %>
  </div>

  <div>
    <%= f.label :resource_identifier, "Resource ID", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :resource_identifier, placeholder: "Optional: specific resource UUID or identifier", class: "w-full border border-gray-300 rounded p-2 text-sm" %>
    <p class="text-xs text-gray-500 mt-1">Leave blank to allow access to all instances of this resource type</p>
  </div>

  <div class="flex gap-2 pt-2">
    <%= f.submit @resource.new_record? ? "Add Resource" : "Update Resource", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded text-sm transition" %>
    <%= link_to "Cancel", ai_agent_path(@agent), class: "bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded text-sm transition" %>
  </div>
<% end %>
