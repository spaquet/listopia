<!-- app/views/collaborations/_share_modal.html.erb -->
<div class="modal-backdrop" data-controller="modal" data-action="click->modal#clickOutside">
  <div class="modal-content w-full max-w-lg" data-modal-target="modal" role="dialog" aria-labelledby="modal-title">
    <!-- Header -->
    <div class="modal-header">
      <div>
        <h2 id="modal-title">Share <%= resource_type == 'ListItem' ? 'Task' : 'List' %></h2>
        <p class="text-sm text-ink-muted mt-1"><%= resource.title %></p>
      </div>
      <button class="modal-close" data-action="click->modal#close">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="modal-body space-y-6">
        <!-- Current Collaborators Section -->
        <div>
          <h3 class="text-sm font-medium text-ink mb-3">Current Collaborators</h3>
          <div id="collaborators-list" class="space-y-2 max-h-48 overflow-y-auto">
            <% if collaborators.any? %>
              <% collaborators.each do |collaborator| %>
                <div class="flex items-center justify-between p-3 bg-surface-sunken rounded-lg">
                  <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 rounded-full bg-accent-soft flex items-center justify-center text-sm font-medium text-accent">
                      <%= collaborator.user.name&.first&.upcase || collaborator.user.email[0].upcase %>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-ink"><%= collaborator.user.name %></p>
                      <p class="text-xs text-ink-muted"><%= collaborator.user.email %></p>
                    </div>
                  </div>
                  <div class="flex items-center space-x-2">
                    <span class="pill <%= collaborator.permission_write? ? 'accent' : '' %>">
                      <%= collaborator.permission_write? ? 'Can Edit' : 'Can View' %>
                    </span>
                    <% if can_remove_collaborator %>
                      <%= button_to collaboration_path_for(resource, collaborator),
                                  method: :delete,
                                  class: "p-1 text-ink-muted hover:text-danger hover:bg-surface-sunken rounded transition-colors",
                                  title: "Remove collaborator" do %>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p class="text-sm text-ink-muted text-center py-4">No collaborators yet</p>
            <% end %>
          </div>
        </div>

        <!-- Pending Invitations Section -->
        <% if pending_invitations.any? %>
          <div class="border-t border-rule pt-6">
            <h3 class="text-sm font-medium text-ink mb-3">Pending Invitations</h3>
            <div class="space-y-2 max-h-32 overflow-y-auto">
              <% pending_invitations.each do |invitation| %>
                <div class="flex items-center justify-between p-3 bg-surface-sunken rounded-lg border border-rule-soft">
                  <div>
                    <p class="text-sm text-ink"><%= invitation.email %></p>
                    <p class="text-xs text-ink-muted">Invited <%= time_ago_in_words(invitation.invitation_sent_at) %> ago</p>
                  </div>
                  <div class="flex items-center space-x-2">
                    <span class="pill warning">Pending</span>
                    <% if can_remove_collaborator %>
                      <%= button_to collaboration_path_for(resource, invitation),
                                  method: :delete,
                                  class: "p-1 text-ink-muted hover:text-danger hover:bg-surface-sunken rounded transition-colors",
                                  title: "Cancel invitation" do %>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Invite New Collaborator Form -->
        <% if can_manage_collaborators %>
          <div class="border-t border-rule pt-6">
            <h3 class="text-sm font-medium text-ink mb-3">Invite Person</h3>
            <%= form_with url: collaborations_path_for(resource), method: :post, local: true, class: "space-y-4" do |f| %>
              <div class="space-y-3">
                <!-- Email Input -->
                <div>
                  <%= f.label :email, "Email Address", class: "form-label" %>
                  <%= f.email_field :email,
                                   placeholder: "person@example.com",
                                   required: true,
                                   class: "form-input" %>
                </div>

                <!-- Permission Level -->
                <div>
                  <%= f.label :permission, "Permission Level", class: "form-label" %>
                  <div class="space-y-2">
                    <label class="flex items-center cursor-pointer">
                      <%= f.radio_button :permission, 'read', checked: true, class: "radio" %>
                      <span class="ml-3">
                        <span class="text-sm font-medium text-ink">Can View</span>
                        <span class="text-xs text-ink-muted block">Read-only access</span>
                      </span>
                    </label>
                    <label class="flex items-center cursor-pointer">
                      <%= f.radio_button :permission, 'write', class: "radio" %>
                      <span class="ml-3">
                        <span class="text-sm font-medium text-ink">Can Edit</span>
                        <span class="text-xs text-ink-muted block">Full edit access</span>
                      </span>
                    </label>
                  </div>
                </div>

                <!-- Delegation Option -->
                <div>
                  <label class="flex items-center cursor-pointer">
                    <%= f.check_box :can_invite_collaborators, { class: "checkbox" } %>
                    <span class="ml-3">
                      <span class="text-sm font-medium text-ink">Allow to invite others</span>
                      <span class="text-xs text-ink-muted block">Let them add more collaborators</span>
                    </span>
                  </label>
                </div>
              </div>

              <!-- Action Buttons -->
              <div class="flex gap-3 pt-2">
                <%= f.submit "Send Invite", class: "btn btn-primary flex-1" %>
                <button type="button" class="btn btn-secondary flex-1" data-action="click->modal#close">
                  Cancel
                </button>
              </div>
            <% end %>
          </div>
        <% end %>
    </div>
  </div>
</div>
