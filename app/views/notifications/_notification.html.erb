<!-- app/views/notifications/_notification.html.erb -->
<div id="notification_<%= notification.id %>"
     class="notification-item <%= 'unread' unless notification.read? %>">
  <div class="notification-item-header">
    <!-- Icon -->
    <div class="notification-item-icon-box">
      <%= render "notifications/notification_icon", notification: notification %>
    </div>
    <!-- Content -->
    <div class="flex-1 min-w-0">
      <!-- Title and message -->
      <div class="flex items-center gap-2 mb-1">
        <h3 class="notification-item-title">
          <%= notification.title %>
        </h3>
        <% unless notification.read? %>
          <span class="notification-item-badge">
            New
          </span>
        <% end %>
      </div>
      <p class="notification-item-message">
        <%= notification.message %>
      </p>
      <!-- State changes (if applicable) -->
      <% if notification.respond_to?(:previous_status) && notification.previous_status.present? %>
        <div class="notification-item-status-change">
          <div class="notification-item-status-change-row">
            <div class="flex items-center gap-2">
              <span class="notification-item-status-label">From:</span>
              <span class="notification-item-status-badge">
                <%= notification.previous_status.humanize %>
              </span>
            </div>
            <svg class="notification-item-status-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <div class="flex items-center gap-2">
              <span class="notification-item-status-label">To:</span>
              <span class="notification-item-status-badge">
                <%= notification.new_status.humanize %>
              </span>
            </div>
          </div>
        </div>
      <% end %>
      <!-- Meta info -->
      <div class="notification-item-meta">
        <div class="notification-item-meta-item">
          <svg class="notification-item-meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span><%= time_ago_in_words(notification.created_at) %> ago</span>
        </div>
        <% if notification.respond_to?(:actor) && notification.actor %>
          <div class="notification-item-meta-item">
            <svg class="notification-item-meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <span>by <%= notification.actor.name %></span>
          </div>
        <% end %>
        <% if notification.respond_to?(:target_list) && notification.target_list %>
          <div class="notification-item-meta-item">
            <svg class="notification-item-meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
            <span><%= notification.target_list.title %></span>
          </div>
        <% end %>
      </div>
    </div>
    <!-- Actions -->
    <div class="notification-item-actions">
      <!-- Mark as read button -->
      <% unless notification.read? %>
        <%= button_to mark_as_read_notification_path(notification),
                      method: :patch,
                      remote: true,
                      class: "notification-item-action-link" do %>
          Mark read
        <% end %>
      <% end %>
      <!-- View button -->
      <%= link_to notification.url,
                  class: "notification-item-action-link",
                  data: { turbo: false } do %>
        View
      <% end %>
    </div>
  </div>
</div>