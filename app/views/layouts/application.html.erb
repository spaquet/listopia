<!DOCTYPE html>
<html data-theme="editorial" data-controller="theme">
  <head>
    <title><%= content_for(:title) || "Listopia" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body class="bg-surface text-ink min-h-screen transition-colors duration-base" data-controller="error-handler keyboard-shortcuts spotlight-trigger">
    <%= render "shared/navigation" %>
    <%= render "shared/flash_messages" %>
    <!-- Main Content -->
    <main class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
    <!-- Modal Containers -->
    <%= turbo_frame_tag "modal" %>
    <%= turbo_frame_tag "org_switcher_modal" %>
    <%= turbo_frame_tag "spotlight_modal" %>
    <!-- Error Handler Notification Container -->
    <div data-error-handler-target="notification" class="hidden"></div>
    <!-- Floating Chat Widget (on all pages) -->
    <% if user_signed_in? && @floating_chat.present? && @floating_chat_context.present? %>
      <%= render "chat/floating_chat" %>
    <% end %>

    <!-- Theme Console Helpers (wires Stimulus controller to console) -->
    <script>
      const htmlElement = document.documentElement;
      window.themeToggle = () => {
        htmlElement.dispatchEvent(new CustomEvent('theme:toggle'));
        console.log(`✓ Theme: ${htmlElement.getAttribute("data-theme")}`);
      };
      window.themeSet = (name) => {
        if (!["editorial", "console"].includes(name)) {
          console.error("Invalid theme. Use 'editorial' or 'console'");
          return;
        }
        htmlElement.setAttribute("data-theme", name);
        localStorage.setItem("theme-preference", name);
        console.log(`✓ Theme: ${name}`);
      };
      console.log(`
🎨 Theme Control (uses existing Stimulus controller)
  themeToggle()        — Switch between editorial (light) & console (dark)
  themeSet('editorial') or themeSet('console') — Set specific theme
      `);
    </script>
  </body>
</html>
