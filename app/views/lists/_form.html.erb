<!-- app/views/lists/_form.html.erb -->
<%= form_with model: list , local: false, class: "space-y-6" do |f| %>
  <!-- Error Messages -->
  <% if list.errors.any? %>
    <div class="alert alert-danger">
      <div class="alert-icon">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="alert-content">
        <h3 class="alert-title">Please fix the following errors:</h3>
        <ul class="mt-2 text-sm text-danger list-disc list-inside">
          <% list.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
  <!-- Title Field -->
  <div>
    <%= f.label :title, "Title", class: "form-label" %>
    <%= f.text_field :title,
                     placeholder: "Enter a descriptive title for your list",
                     class: "form-input" %>
  </div>
  <!-- Description Field -->
  <div>
    <%= f.label :description, "Description (optional)", class: "form-label" %>
    <%= f.text_area :description,
                    rows: 3,
                    placeholder: "Add a brief description of what this list is for",
                    class: "form-input" %>
  </div>
  <!-- Status and List Type Fields -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- Status Field -->
    <div>
      <%= f.label :status, "Status", class: "form-label" %>
      <%= f.select :status,
                   options_for_select([
                     ['Draft', 'draft'],
                     ['Active', 'active'],
                     ['Completed', 'completed'],
                     ['Archived', 'archived']
                   ], list.status || 'active'),
                   {},
                   { class: "form-input" } %>
    </div>
    <!-- List Type Field -->
    <div>
      <%= f.label :list_type, "Type", class: "form-label" %>
      <%= f.select :list_type,
                   options_for_select([
                     ['Personal', 'personal'],
                     ['Professional', 'professional']
                   ], list.list_type || 'personal'),
                   {},
                   { class: "form-input" } %>
    </div>
  </div>
  <!-- Public Access Checkbox -->
  <div class="flex items-center space-x-3">
    <%= f.check_box :is_public, class: "checkbox" %>
    <%= f.label :is_public, "Make this list publicly viewable", class: "text-sm text-ink" %>
  </div>
  <!-- Form Actions -->
  <div class="flex items-center justify-between pt-6 border-t border-rule">
    <!-- Check if this is a turbo frame request (modal) -->
    <% if turbo_frame_request? %>
      <!-- Modal context: close button -->
      <button type="button"
              data-action="click->modal#close"
              class="btn btn-secondary">
        Cancel
      </button>
    <% else %>
      <!-- Regular page context: back link -->
      <%= link_to lists_path, class: "btn btn-secondary" do %>
        Cancel
      <% end %>
    <% end %>
    <%= f.submit list.persisted? ? "Update List" : "Create List",
                 class: "btn btn-primary" %>
  </div>
<% end %>