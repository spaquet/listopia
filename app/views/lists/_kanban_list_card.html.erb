<!-- app/views/lists/_kanban_list_card.html.erb -->
<div class="kanban-card">
  <!-- Quick Actions (on hover) -->
  <div class="kanban-card-actions">
    <% if current_user && can_edit_list?(list, current_user) %>
      <!-- Edit -->
      <%= link_to edit_list_path(list),
                  class: "kanban-card-action",
                  title: "Edit" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
      <% end %>

      <!-- Delete -->
      <% if can_delete_list?(list, current_user) %>
        <%= button_to list_path(list),
                      method: :delete,
                      data: { turbo_confirm: "Delete this list?" },
                      class: "kanban-card-action delete",
                      title: "Delete" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <!-- List Type Badge -->
  <div class="kanban-card-badges">
    <% if list.list_type == 'professional' %>
      <span class="pill accent">Professional</span>
    <% elsif list.list_type == 'personal' %>
      <span class="pill success">Personal</span>
    <% end %>
  </div>

  <!-- Title & Link -->
  <h4 class="kanban-card-title">
    <%= link_to list.title, list_path(list) %>
  </h4>

  <!-- Description (if present) -->
  <% if list.description.present? %>
    <p class="text-xs text-ink-muted mb-3 line-clamp-1">
      <%= list.description %>
    </p>
  <% end %>

  <!-- Stats Row -->
  <div class="kanban-card-meta">
    <div class="flex items-center gap-2">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
      </svg>
      <span><%= pluralize(list.list_items_count, 'item') %></span>
      <% if list.list_items_count > 0 %>
        <span class="text-ink font-semibold">
          <%= ((list.list_items.status_completed.count.to_f / list.list_items_count) * 100).round %>%
        </span>
      <% end %>
    </div>
  </div>

  <!-- Progress Bar -->
  <% if list.list_items_count > 0 %>
    <div class="progress-bar mb-0">
      <div class="progress-bar-fill" style="width: <%= ((list.list_items.status_completed.count.to_f / list.list_items_count) * 100).round %>%"></div>
    </div>
  <% end %>

  <!-- Owner Info -->
  <div class="kanban-card-assignee">
    <div class="kanban-card-assignee-avatar">
      <%= list.owner.email[0].upcase %>
    </div>
    <span class="truncate"><%= list.owner.email.split('@')[0] %></span>
  </div>

  <!-- View Button -->
  <%= link_to list_path(list),
              class: "kanban-card-action-button" do %>
    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
    </svg>
    View List
  <% end %>
</div>
