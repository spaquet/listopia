<!-- app/views/lists/_share_modal_content.html.erb -->
<div id="share_modal" class="space-y-6">
  <!-- Public Access Toggle -->
  <div class="space-y-4">
    <div class="flex items-center justify-between">
      <div>
        <h4 class="text-sm font-medium text-ink">Public Access</h4>
        <p class="text-xs text-ink-muted">Allow anyone with the link to view this list</p>
      </div>
      <%= form_with url: toggle_public_access_list_path(list), method: :patch, local: false, class: "inline-block" do |f| %>
        <input type="checkbox" class="toggle" <%= "checked" if list.is_public? %> onchange="this.form.submit()">
      <% end %>
    </div>
    <% if list.is_public? %>
      <!-- Pretty Public URL -->
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-ink mb-2">
            Pretty Share Link
            <span class="text-xs text-ink-muted font-normal">(Recommended for sharing)</span>
          </label>
          <div class="flex">
            <% public_url = list.public_slug.present? ? "#{request.base_url}/public/#{list.public_slug}" : sharing_summary[:public_url] %>
            <input type="text"
                   value="<%= public_url %>"
                   readonly
                   class="flex-1 px-3 py-2 bg-surface-sunken border border-rule rounded-l-lg text-sm font-mono text-ink-muted focus:outline-none">
            <button data-controller="clipboard"
                    data-clipboard-text-value="<%= public_url %>"
                    data-clipboard-success-message-value="Pretty link copied!"
                    data-action="click->clipboard#copy"
              class="px-4 py-2 bg-accent text-ink-inverse rounded-r-lg hover:opacity-90 transition-opacity duration-200 text-sm font-medium flex items-center space-x-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
              <span>Copy</span>
            </button>
          </div>
        </div>
        <!-- Public Access Info -->
        <div class="alert alert-info">
          <div class="flex items-start space-x-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="text-xs">
              <p class="font-medium">Anyone with these links can view this list</p>
              <p class="mt-1">They won't be able to edit or add items unless you invite them as collaborators.</p>
            </div>
          </div>
        </div>
      </div>
    <% else %>
      <!-- Public Access Disabled State -->
      <div class="bg-surface-sunken border border-rule rounded-lg p-4 text-center">
        <svg class="w-8 h-8 text-ink-faint mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
        </svg>
        <p class="text-sm text-ink font-medium">This list is private</p>
        <p class="text-xs text-ink-muted mt-1">Enable public access above to generate shareable links</p>
      </div>
    <% end %>
  </div>
  <!-- Collaboration Section -->
  <div class="border-t border-rule pt-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h4 class="text-sm font-medium text-ink">Collaborators</h4>
        <p class="text-xs text-ink-muted">Invite people to view or edit this list</p>
      </div>
      <%= link_to list_collaborations_path(list),
                  class: "text-sm text-accent hover:text-accent font-medium flex items-center space-x-1" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        <span>Manage</span>
      <% end %>
    </div>
    <!-- Quick Collaborator Stats -->
    <div class="flex items-center space-x-4 text-xs text-ink-muted">
      <div class="flex items-center space-x-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
        </svg>
        <span><%= list.collaborators.permission_read.count %> viewers</span>
      </div>
      <div class="flex items-center space-x-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        <span><%= list.collaborators.permission_write.count %> editors</span>
      </div>
    </div>
  </div>
</div>