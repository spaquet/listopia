<!-- app/views/lists/_filters.html.erb -->
<div class="card p-4"
     data-controller="list-filter"
     data-list-filter-debounce-delay="300">
  <div class="flex flex-col space-y-4">
    <!-- Search -->
    <div class="w-full">
      <%= form_with url: lists_path, method: :get, local: true, class: "w-full",
                    data: {
                      list_filter_target: "form"
                    } do |f| %>
        <div class="relative" data-turbo-permanent id="search-field-container">
          <%= f.text_field :search,
                           value: params[:search],
                           placeholder: "Search lists...",
                           class: "form-input pl-10 pr-10 w-full",
                           data: {
                             action: "input->list-filter#handleSearchInput",
                             list_filter_target: "searchInput"
                           },
                           autocomplete: "off",
                           spellcheck: "false" %>
          <!-- Search Icon -->
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="w-5 h-5 text-ink-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <!-- Clear Button for Search -->
          <button type="button"
                  class="absolute inset-y-0 right-0 pr-3 flex items-center<%= params[:search].present? ? '' : ' hidden' %>"
                  data-action="click->list-filter#clearFilters"
                  data-list-filter-target="clearBtn">
            <svg class="w-5 h-5 text-ink-muted hover:text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      <% end %>
    </div>
    <!-- Filter Tabs -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between space-y-4 sm:space-y-0 sm:space-x-4">
      <!-- Status Filters -->
      <div class="flex flex-wrap gap-2">
        <span class="t-meta text-ink-muted mr-2 flex items-center">Status:</span>
        <%= link_to lists_path(search: params[:search], visibility: params[:visibility], collaboration: params[:collaboration]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:status].blank? ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "status"
                    } do %>
          All
        <% end %>
        <% %w[active completed archived].each do |status| %>
          <%= link_to lists_path(status: status, search: params[:search], visibility: params[:visibility], collaboration: params[:collaboration]),
                      class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:status] == status ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                      data: {
                        action: "click->list-filter#filterChange",
                        filter_type: "status"
                      } do %>
            <%= status.titleize %>
          <% end %>
        <% end %>
      </div>
      <!-- Visibility Filters -->
      <div class="flex flex-wrap gap-2">
        <span class="t-meta text-ink-muted mr-2 flex items-center">Visibility:</span>
        <%= link_to lists_path(status: params[:status], search: params[:search], collaboration: params[:collaboration]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:visibility].blank? ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "visibility"
                    } do %>
          All
        <% end %>
        <%= link_to lists_path(visibility: 'public', status: params[:status], search: params[:search], collaboration: params[:collaboration]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:visibility] == 'public' ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "visibility"
                    } do %>
          Public
        <% end %>
        <%= link_to lists_path(visibility: 'private', status: params[:status], search: params[:search], collaboration: params[:collaboration]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:visibility] == 'private' ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "visibility"
                    } do %>
          Private
        <% end %>
      </div>
      <!-- Collaboration Filters -->
      <div class="flex flex-wrap gap-2">
        <span class="t-meta text-ink-muted mr-2 flex items-center">Access:</span>
        <%= link_to lists_path(status: params[:status], search: params[:search], visibility: params[:visibility]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:collaboration].blank? ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "collaboration"
                    } do %>
          All
        <% end %>
        <%= link_to lists_path(collaboration: 'owned', status: params[:status], search: params[:search], visibility: params[:visibility]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:collaboration] == 'owned' ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "collaboration"
                    } do %>
          My Lists
        <% end %>
        <%= link_to lists_path(collaboration: 'shared_with_me', status: params[:status], search: params[:search], visibility: params[:visibility]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:collaboration] == 'shared_with_me' ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "collaboration"
                    } do %>
          Shared with Me
        <% end %>
        <%= link_to lists_path(collaboration: 'shared_by_me', status: params[:status], search: params[:search], visibility: params[:visibility]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:collaboration] == 'shared_by_me' ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "collaboration"
                    } do %>
          Shared by Me
        <% end %>
      </div>
      <!-- Parent Lists Toggle -->
      <div class="flex flex-wrap gap-2">
        <span class="t-meta text-ink-muted mr-2 flex items-center">View:</span>
        <%= link_to lists_path(status: params[:status], search: params[:search], visibility: params[:visibility], collaboration: params[:collaboration]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:show_sublists].blank? ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "parent_lists"
                    } do %>
          Parent Lists Only
        <% end %>
        <%= link_to lists_path(show_sublists: 'true', status: params[:status], search: params[:search], visibility: params[:visibility], collaboration: params[:collaboration]),
                    class: "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-fast #{params[:show_sublists] == 'true' ? 'bg-surface-raised border border-rule text-accent' : 'text-ink hover:text-accent hover:bg-surface-raised'}",
                    data: {
                      action: "click->list-filter#filterChange",
                      filter_type: "parent_lists"
                    } do %>
          All Lists
        <% end %>
      </div>
    </div>
    <!-- Active Filters Summary (when multiple filters are applied) -->
    <% if params[:search].present? || params[:status].present? || params[:visibility].present? || params[:collaboration].present? || params[:show_sublists].present? %>
      <div id="active-filters" class="alert">
        <div class="flex items-center justify-between w-full">
          <div class="flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.207A1 1 0 013 6.5V4z"></path>
            </svg>
            <span class="t-meta">Active filters:</span>
            <div class="flex flex-wrap gap-2">
              <% if params[:search].present? %>
                <span class="pill accent text-xs">Search: "<%= params[:search] %>"</span>
              <% end %>
              <% if params[:status].present? %>
                <span class="pill accent text-xs">Status: <%= params[:status].titleize %></span>
              <% end %>
              <% if params[:visibility].present? %>
                <span class="pill accent text-xs">Visibility: <%= params[:visibility].titleize %></span>
              <% end %>
              <% if params[:collaboration].present? %>
                <span class="pill accent text-xs">
                  Access: <%= params[:collaboration].humanize.titleize %>
                </span>
              <% end %>
              <% if params[:show_sublists].present? %>
                <span class="pill accent text-xs">View: All Lists</span>
              <% end %>
            </div>
          </div>
          <%= link_to lists_path,
                      class: "text-accent hover:opacity-80 font-medium text-sm transition-opacity duration-fast",
                      data: {
                        action: "click->list-filter#clearFilters"
                      } do %>
            Clear all
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
