<div class="email-header">
  <h1>Your Listopia Magic Link</h1>
</div>

<div class="email-body">
  <p>Hi <%= @user.name %>,</p>
  <p>Click the button below to sign in to your Listopia account instantly:</p>
  <div style="text-align: center;">
    <a href="<%= @login_url %>" class="button">Sign In to Listopia</a>
  </div>
  <p>If the button doesn't work, you can copy and paste this link into your browser:</p>
  <p style="word-break: break-all; background-color: #f7f4ee; padding: 10px; border-radius: 4px; border: 1px solid #d9d2c1; font-family: monospace; font-size: 12px;">
    <%= @login_url %>
  </p>
  <p><strong>Important:</strong> This link will expire in 15 minutes for security reasons.</p>
  <div class="divider"></div>
  <p style="margin-top: 20px;">Questions? <a href="<%= root_url %>" style="color: #8a2c2c; text-decoration: none;">Visit Listopia</a></p>
</div>
      <div class="footer">
        <p>If you didn't request this magic link, you can safely ignore this email.</p>
        <p>Thanks,<br>
          The Listopia Team</p>
      </div>
    </div>
  </body>
</html>
