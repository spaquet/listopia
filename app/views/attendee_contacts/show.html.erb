<%= turbo_frame_tag @contact, class: "block" do %>
  <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-lg shadow-lg max-w-2xl w-full max-h-[90vh] overflow-y-auto">
      <!-- Header with close button -->
      <div class="sticky top-0 bg-white border-b border-gray-200 p-6 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <% if @contact.avatar_url.present? %>
            <img src="<%= @contact.avatar_url %>" alt="<%= @contact.name %>" class="w-16 h-16 rounded-full object-cover">
          <% else %>
            <div class="w-16 h-16 rounded-full bg-gray-300 flex items-center justify-center text-2xl font-medium text-gray-600">
              <%= @contact.name.first.upcase %>
            </div>
          <% end %>
          <div>
            <h2 class="text-2xl font-bold text-gray-900"><%= @contact.name %></h2>
            <p class="text-sm text-gray-600"><%= @contact.email %></p>
          </div>
        </div>
        <button type="button" data-action="click->modal-opener#closeFrame" class="text-gray-400 hover:text-gray-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Content -->
      <div class="p-6 space-y-6">
        <!-- Professional info -->
        <% if @contact.title.present? || @contact.company.present? || @contact.location.present? %>
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-3">Professional</h3>
            <div class="space-y-2">
              <% if @contact.title.present? %>
                <p class="text-sm"><span class="text-gray-600">Title:</span> <span class="font-medium text-gray-900"><%= @contact.title %></span></p>
              <% end %>
              <% if @contact.company.present? %>
                <p class="text-sm"><span class="text-gray-600">Company:</span> <span class="font-medium text-gray-900"><%= @contact.company %></span></p>
              <% end %>
              <% if @contact.location.present? %>
                <p class="text-sm"><span class="text-gray-600">Location:</span> <span class="font-medium text-gray-900"><%= @contact.location %></span></p>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Bio -->
        <% if @contact.bio.present? %>
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Bio</h3>
            <p class="text-sm text-gray-700"><%= @contact.bio %></p>
          </div>
        <% end %>

        <!-- Social links -->
        <% if @contact.linkedin_url.present? || @contact.github_username.present? || @contact.twitter_url.present? || @contact.website_url.present? %>
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-3">Social & Web</h3>
            <div class="flex gap-3 flex-wrap">
              <% if safe_url(@contact.linkedin_url) %>
                <%= link_to "LinkedIn", safe_url(@contact.linkedin_url), target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center gap-2 px-3 py-2 bg-blue-100 text-blue-800 rounded-lg hover:bg-blue-200 text-sm font-medium" %>
              <% end %>
              <% if @contact.github_username.present? %>
                <%= link_to "GitHub", "https://github.com/#{@contact.github_username}", target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center gap-2 px-3 py-2 bg-gray-100 text-gray-800 rounded-lg hover:bg-gray-200 text-sm font-medium" %>
              <% end %>
              <% if safe_url(@contact.twitter_url) %>
                <%= link_to "Twitter", safe_url(@contact.twitter_url), target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center gap-2 px-3 py-2 bg-sky-100 text-sky-800 rounded-lg hover:bg-sky-200 text-sm font-medium" %>
              <% end %>
              <% if safe_url(@contact.website_url) %>
                <%= link_to "Website", safe_url(@contact.website_url), target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center gap-2 px-3 py-2 bg-purple-100 text-purple-800 rounded-lg hover:bg-purple-200 text-sm font-medium" %>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Recent shared meetings -->
        <% if @shared_meetings.any? %>
          <div>
            <h3 class="text-lg font-semibold text-gray-900 mb-3">Recent Shared Meetings</h3>
            <div class="space-y-2">
              <% @shared_meetings.each do |meeting| %>
                <div class="p-3 bg-gray-50 rounded-lg border border-gray-200">
                  <p class="font-medium text-gray-900 text-sm"><%= meeting.summary %></p>
                  <p class="text-xs text-gray-600 mt-1">
                    <%= meeting.start_time.strftime("%b %d, %Y at %l:%M %p") %>
                  </p>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Edit enrichment form -->
        <div class="border-t border-gray-200 pt-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">Edit Information</h3>
          <%= form_with model: @contact, local: true, class: "space-y-4" do |f| %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <%= f.label :title, "Job Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= f.text_field :title, placeholder: "e.g. Senior Engineer",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              <div>
                <%= f.label :company, "Company", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= f.text_field :company, placeholder: "e.g. Acme Inc",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              <div>
                <%= f.label :location, "Location", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= f.text_field :location, placeholder: "e.g. San Francisco, CA",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              <div>
                <%= f.label :linkedin_url, "LinkedIn URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= f.text_field :linkedin_url, placeholder: "https://linkedin.com/in/...",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              <div>
                <%= f.label :github_username, "GitHub Username", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= f.text_field :github_username, placeholder: "e.g. octocat",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              <div>
                <%= f.label :twitter_url, "Twitter URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= f.text_field :twitter_url, placeholder: "https://twitter.com/...",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              <div class="md:col-span-2">
                <%= f.label :website_url, "Website", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= f.text_field :website_url, placeholder: "https://example.com",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
            </div>
            <div class="flex gap-2 justify-end">
              <button type="button" data-action="click->modal-opener#closeFrame" class="px-4 py-2 text-gray-700 hover:text-gray-900 font-medium">
                Cancel
              </button>
              <%= f.submit "Save Changes", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
