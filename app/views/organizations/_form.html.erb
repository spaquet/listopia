<%= form_with model: @organization, local: true, class: "space-y-6" do |f| %>
  <% if @organization.errors.any? %>
    <div class="alert alert-danger">
      <div class="alert-icon">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="alert-content">
        <h3 class="alert-title">
          <%= pluralize(@organization.errors.count, "error") %> prevented this organization from being saved:
        </h3>
        <ul class="mt-2 text-sm list-disc list-inside">
          <% @organization.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Organization Name", class: "form-label" %>
    <%= f.text_field :name,
      class: "form-input",
      placeholder: "My Organization",
      required: true
    %>
    <p class="mt-1 text-xs text-ink-muted">The name of your organization</p>
  </div>

  <div>
    <%= f.label :size, "Organization Size", class: "form-label" %>
    <%= f.select :size,
      [["Small (1-10 members)", "small"], ["Medium (11-50 members)", "medium"], ["Large (51-200 members)", "large"], ["Enterprise (200+ members)", "enterprise"]],
      { selected: @organization.size || "small" },
      class: "form-input"
    %>
    <p class="mt-1 text-xs text-ink-muted">Helps us provide the right support for your organization</p>
  </div>

  <div class="flex gap-2">
    <%= f.submit @organization.persisted? ? "Update Organization" : "Create Organization",
      class: "btn btn-primary"
    %>
    <%= link_to "Cancel",
      @organization.persisted? ? organization_path(@organization) : organizations_path,
      class: "btn btn-secondary"
    %>
  </div>
<% end %>
