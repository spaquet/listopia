<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="t-display-m text-ink"><%= @organization.name %></h1>
      <p class="mt-2 text-ink-muted space-x-2">
        <span class="pill accent">
          <%= @organization.size.titleize %>
        </span>
        <span class="<%= @organization.status_active? ? 'pill success' : 'pill danger' %>">
          <%= @organization.status.titleize %>
        </span>
      </p>
    </div>
    <div class="flex gap-2">
      <% if policy(@organization).update? %>
        <%= link_to "Edit", edit_organization_path(@organization), class: "btn btn-secondary" %>
      <% end %>
      <% if policy(@organization).manage_members? %>
        <%= link_to "Manage Members", organization_members_path(@organization), class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="card">
      <div class="t-meta text-ink-muted">Total Members</div>
      <div class="t-display-m text-ink mt-1"><%= @organization.users.count %></div>
    </div>
    <div class="card">
      <div class="t-meta text-ink-muted">Teams</div>
      <div class="t-display-m text-ink mt-1"><%= @organization.teams.count %></div>
    </div>
    <div class="card">
      <div class="t-meta text-ink-muted">Lists</div>
      <div class="t-display-m text-ink mt-1"><%= @organization.lists.count %></div>
    </div>
  </div>

  <div class="card">
    <h2 class="t-body-l font-semibold text-ink mb-4">Organization Details</h2>
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <dt class="t-meta text-ink-muted">Slug</dt>
        <dd class="mt-1 text-ink"><%= @organization.slug %></dd>
      </div>
      <div>
        <dt class="t-meta text-ink-muted">Created</dt>
        <dd class="mt-1 text-ink"><%= @organization.created_at.strftime("%B %d, %Y") %></dd>
      </div>
      <div>
        <dt class="t-meta text-ink-muted">Created By</dt>
        <dd class="mt-1 text-ink"><%= @organization.creator.email %></dd>
      </div>
      <div>
        <dt class="t-meta text-ink-muted">Status</dt>
        <dd class="mt-1">
          <span class="<%= @organization.status_active? ? 'pill success' : 'pill danger' %>">
            <%= @organization.status.titleize %>
          </span>
        </dd>
      </div>
    </dl>
  </div>

  <% if policy(@organization).manage_members? %>
    <div class="card">
      <h2 class="t-body-l font-semibold text-ink mb-4">Recent Members</h2>
      <div class="divide-y divide-rule">
        <% @organization.organization_memberships.active.order(joined_at: :desc).limit(5).each do |membership| %>
          <div class="flex items-center justify-between py-3">
            <div>
              <p class="font-medium text-ink"><%= membership.user.name %></p>
              <p class="t-meta text-ink-muted"><%= membership.user.email %></p>
            </div>
            <div class="flex items-center gap-3">
              <span class="pill accent">
                <%= membership.role.titleize %>
              </span>
              <% if policy(@organization).manage_members? %>
                <%= link_to "Manage", organization_member_path(@organization, membership), class: "t-body-s text-accent hover:text-accent" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <%= link_to "View All Members", organization_members_path(@organization), class: "mt-4 inline-block text-accent hover:text-accent t-body-s font-medium" %>
    </div>
  <% end %>

  <div class="flex gap-2">
    <% if policy(@organization).suspend? && @organization.status_active? %>
      <%= link_to "Suspend Organization", suspend_organization_path(@organization), method: :post, data: { confirm: "Are you sure? This will prevent all members from accessing the organization." }, class: "btn btn-warning" %>
    <% elsif policy(@organization).reactivate? && @organization.status_suspended? %>
      <%= link_to "Reactivate Organization", reactivate_organization_path(@organization), method: :post, class: "btn btn-success" %>
    <% end %>
    <% if policy(@organization).destroy? %>
      <%= link_to "Delete Organization", organization_path(@organization), method: :delete, data: { confirm: "Are you sure? This action cannot be undone." }, class: "btn btn-danger" %>
    <% end %>
  </div>
</div>
