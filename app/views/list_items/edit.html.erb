<!-- app/views/list_items/edit.html.erb -->
<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-ink/50 overflow-y-auto h-full w-full z-50 flex items-center justify-center p-4"
       data-controller="modal"
       data-modal-target="modal">
    <div class="relative bg-surface rounded-md shadow-pop max-w-2xl w-full mx-auto border border-rule max-h-[90vh] overflow-y-auto"
         data-modal-target="backdrop"
         data-action="click->modal#clickOutside">
      <!-- Modal Header -->
      <div class="flex items-center justify-between p-6 border-b border-rule sticky top-0 bg-surface rounded-t-md">
        <div class="flex-1">
          <h2 class="text-lg font-semibold text-ink">Edit Item</h2>
          <p class="text-sm text-ink-muted mt-1"><%= @list.title %></p>
        </div>
        <button data-action="click->modal#close"
          class="ml-4 text-ink-muted hover:text-ink transition-colors duration-200 shrink-0">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="p-6 overflow-y-auto">
        <%= form_with model: [@list, @list_item], local: true, class: "space-y-6", data: { controller: "date-calculator" } do |f| %>
          <!-- Error Messages -->
          <% if @list_item.errors.any? %>
            <div class="alert alert-danger">
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 text-danger mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <h3 class="text-sm font-medium text-danger">Please fix the following errors:</h3>
                  <ul class="mt-2 text-sm text-danger list-disc list-inside space-y-1">
                    <% @list_item.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Content Section -->
          <div class="space-y-4">
            <h3 class="text-sm font-semibold text-ink">Content</h3>
            <!-- Title Field -->
            <div>
              <%= f.label :title, class: "form-label" %>
              <%= f.text_field :title,
                              placeholder: "Item title...",
                              class: "form-input" %>
            </div>
            <!-- Description Field -->
            <div data-controller="wysiwyg-markdown">
              <%= f.label :description, class: "form-label" do %>
                Description <span class="text-xs font-normal text-ink-muted">(optional, markdown)</span>
              <% end %>
              <div data-wysiwyg-markdown-target="editor" class="border border-rule rounded-md bg-surface-sunken"></div>
              <%= f.hidden_field :description, data: { "wysiwyg-markdown-target": "input" } %>
            </div>
          </div>

          <!-- Classification Section -->
          <div class="space-y-4">
            <h3 class="text-sm font-semibold text-ink">Classification</h3>
            <div class="grid grid-cols-3 gap-4">
              <!-- Type Select -->
              <div>
                <%= f.label :item_type, "Type", class: "form-label" %>
                <%= f.select :item_type,
                            options_for_select([
                              ['Task', 'task'],
                              ['Milestone', 'milestone'],
                              ['Feature', 'feature'],
                              ['Bug', 'bug'],
                              ['Idea', 'idea'],
                              ['Note', 'note'],
                              ['Reference', 'reference'],
                              ['Decision', 'decision'],
                              ['Travel', 'travel'],
                              ['Shopping', 'shopping'],
                              ['Learning', 'learning'],
                              ['Health', 'health'],
                              ['Finance', 'finance'],
                              ['Home', 'home'],
                              ['Social', 'social'],
                              ['Habit', 'habit']
                            ], @list_item.item_type),
                            {},
                            class: "form-input" %>
              </div>
              <!-- Priority Select -->
              <div>
                <%= f.label :priority, "Priority", class: "form-label" %>
                <%= f.select :priority,
                            options_for_select([
                              ['Low', 'low'],
                              ['Medium', 'medium'],
                              ['High', 'high'],
                              ['Urgent', 'urgent']
                            ], @list_item.priority),
                            {},
                            class: "form-input" %>
              </div>
              <!-- Status Select -->
              <div>
                <%= f.label :status, "Status", class: "form-label" %>
                <%= f.select :status,
                            options_for_select([
                              ['Pending', 'pending'],
                              ['In Progress', 'in_progress'],
                              ['Completed', 'completed']
                            ], @list_item.status),
                            {},
                            class: "form-input" %>
              </div>
            </div>
          </div>

          <!-- Timeline Section -->
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <h3 class="text-sm font-semibold text-ink">Timeline</h3>
              <button type="button" data-action="date-calculator#clearAllDates" class="text-xs text-danger hover:text-danger font-medium transition-colors">
                Clear all
              </button>
            </div>
            <div class="grid grid-cols-3 gap-4">
              <!-- Start Date -->
              <div>
                <div class="flex items-center justify-between mb-1">
                  <%= f.label :start_date, class: "form-label" do %>
                    Start Date
                  <% end %>
                  <button type="button" data-action="date-calculator#setTodayStartDate" class="text-xs text-accent hover:text-accent font-medium transition-colors">
                    Today
                  </button>
                </div>
                <% is_recent_default = @list_item.start_date && @list_item.updated_at && (@list_item.updated_at - @list_item.start_date).abs < 60.seconds
                   start_date_value = (is_recent_default && @list_item.updated_at == @list_item.created_at) ? nil : @list_item.start_date&.strftime("%Y-%m-%dT%H:%M") %>
                <%= f.datetime_local_field :start_date,
                                           value: start_date_value,
                                           placeholder: "YYYY-MM-DD HH:MM",
                                           data: { "date-calculator-target": "startDate", action: "date-calculator#onStartDateChange" },
                                           class: "form-input" %>
              </div>
              <!-- Duration Days -->
              <div>
                <div class="flex items-center justify-between mb-1">
                  <%= f.label :duration_days, class: "form-label" do %>
                    Duration (Days)
                  <% end %>
                  <button type="button" data-action="date-calculator#clearDuration" class="text-xs text-danger hover:text-danger font-medium transition-colors">
                    Clear
                  </button>
                </div>
                <% duration_value = @list_item.duration_days.to_i > 0 ? @list_item.duration_days : nil %>
                <%= f.number_field :duration_days,
                                  value: duration_value,
                                  min: 0,
                                  placeholder: "value in days",
                                  data: { "date-calculator-target": "duration", action: "date-calculator#onDurationChange" },
                                  class: "form-input" %>
              </div>
              <!-- Due Date -->
              <div>
                <%= f.label :due_date, class: "form-label" do %>
                  Due Date
                <% end %>
                <% due_date_value = @list_item.due_date&.strftime("%Y-%m-%dT%H:%M") %>
                <%= f.datetime_local_field :due_date,
                                           value: due_date_value,
                                           placeholder: "YYYY-MM-DD HH:MM",
                                           data: { "date-calculator-target": "dueDate", action: "date-calculator#onDueDateChange" },
                                           class: "form-input" %>
              </div>
            </div>
          </div>

          <!-- Recurrence Section -->
          <div class="space-y-4">
            <h3 class="text-sm font-semibold text-ink">Recurrence</h3>
            <%= render 'list_items/recurrence_fields', form_object: f, item: @list_item %>
          </div>

          <!-- Assignment & Links Section -->
          <div class="space-y-4">
            <h3 class="text-sm font-semibold text-ink">Assignment & Links</h3>
            <div class="grid grid-cols-2 gap-4">
              <!-- Assigned User -->
              <div>
                <%= f.label :assigned_user_id, "Assign To", class: "form-label" %>
                <%
                  assignable_users = [current_user, @list.owner]
                  assignable_users.concat(@list.collaborator_users)
                  assignable_users = assignable_users.uniq(&:id)
                %>
                <%= f.select :assigned_user_id,
                             options_from_collection_for_select(assignable_users, :id, ->(user) { format_assignee_name(user) }, @list_item.assigned_user_id),
                             { prompt: "Unassigned" },
                             class: "form-input" %>
              </div>
              <!-- URL Field -->
              <div>
                <%= f.label :url, class: "form-label" do %>
                  Link <span class="text-xs font-normal text-ink-muted">(optional)</span>
                <% end %>
                <%= f.url_field :url,
                               placeholder: "https://example.com",
                               class: "form-input" %>
              </div>
            </div>
          </div>

          <!-- Form Actions -->
          <div class="flex gap-2 pt-4 border-t border-rule">
            <%= f.submit "Save Changes",
                        class: "btn btn-primary" %>
            <button type="button" data-action="click->modal#close"
              class="btn btn-secondary">
              Cancel
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
