<!-- app/views/list_items/_quick_add_form.html.erb -->
<div data-controller="quick-add" class="space-y-4">
  <%= form_with model: [ list, list_item ],
                data: {
                  turbo_frame: "new_list_item",
                  action: "turbo:submit-end->quick-add#reset turbo:submit-start->quick-add#clearError"
                },
                class: "space-y-4" do |f| %>
    <!-- Error container with consistent ID -->
    <div id="form-errors">
      <% if list_item.errors.any? %>
        <div class="alert alert-danger">
          <div class="flex items-start space-x-2">
            <svg class="w-4 h-4 text-danger mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <h4 class="text-sm font-medium text-danger">Please fix the following errors:</h4>
              <ul class="mt-1 text-xs text-danger list-disc list-inside">
                <% list_item.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="flex items-start space-x-4">
      <div class="flex-1">
        <%= f.text_field :title,
                         placeholder: "Add a new item...",
                         class: "w-full form-input #{'border-danger focus:border-danger focus:ring-danger' if list_item.errors[:title].any?}",
                         data: {
                           action: "keydown->quick-add#handleKeydown input->quick-add#clearError",
                           "quick-add-target": "titleInput"
                         } %>
      </div>
      <button type="submit"
              data-quick-add-target="submitButton"
              class="btn btn-primary px-6 py-3 flex items-center">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        <span data-quick-add-target="submitText">Add</span>
      </button>
    </div>
    <!-- Expandable options -->
    <div data-quick-add-target="options" class="hidden space-y-4 p-4 bg-surface-raised rounded-md border border-rule">
      <!-- Description Field - Now Above Other Options -->
      <div>
        <%= f.label :description, "Description (optional)", class: "form-label" %>
        <%= f.text_area :description,
                        rows: 2,
                        placeholder: "Add more details...",
                        class: "form-input" %>
      </div>
      <!-- Type, Priority, and Due Date Row -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Type Select -->
        <div>
          <%= f.label :item_type, "Type", class: "form-label" %>
          <%= render 'shared/item_type_select',
                     form_object_name: f.object_name,
                     current_value: list_item.item_type || 'task' %>
        </div>
        <!-- Priority Select -->
        <div>
          <%= f.label :priority, "Priority", class: "form-label" %>
          <div data-controller="custom-select"
               data-custom-select-name-value="<%= f.object_name %>[priority]"
               data-custom-select-value-value="<%= list_item.priority || 'medium' %>">
            <div class="relative">
              <button type="button"
                      data-action="click->custom-select#toggle"
                data-custom-select-target="trigger"
                class="w-full h-11 px-3 py-2 text-left bg-surface-sunken border border-rule rounded-sm shadow-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent flex items-center justify-between text-ink">
                <div class="flex items-center space-x-2" data-custom-select-target="selectedDisplay">
                  <div class="w-2 h-2 rounded-full bg-warning"></div>
                  <span>Medium</span>
                </div>
                <svg class="w-4 h-4 text-ink-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
              <div data-custom-select-target="dropdown"
                   class="hidden absolute z-10 w-full mt-1 bg-surface-raised border border-rule rounded-md shadow-pop">
                <div class="py-1">
                  <button type="button" data-action="click->custom-select#select" data-value="low" class="w-full px-3 py-2 text-left hover:bg-surface-sunken flex items-center space-x-2 text-ink">
                    <div class="w-2 h-2 rounded-full bg-success"></div>
                    <span>Low</span>
                  </button>
                  <button type="button" data-action="click->custom-select#select" data-value="medium" class="w-full px-3 py-2 text-left hover:bg-surface-sunken flex items-center space-x-2 text-ink">
                    <div class="w-2 h-2 rounded-full bg-warning"></div>
                    <span>Medium</span>
                  </button>
                  <button type="button" data-action="click->custom-select#select" data-value="high" class="w-full px-3 py-2 text-left hover:bg-surface-sunken flex items-center space-x-2 text-ink">
                    <div class="w-2 h-2 rounded-full bg-accent"></div>
                    <span>High</span>
                  </button>
                  <button type="button" data-action="click->custom-select#select" data-value="urgent" class="w-full px-3 py-2 text-left hover:bg-surface-sunken flex items-center space-x-2 text-ink">
                    <div class="w-2 h-2 rounded-full bg-danger"></div>
                    <span>Urgent</span>
                  </button>
                </div>
              </div>
              <!-- Hidden input for form submission -->
              <input type="hidden"
                     name="<%= f.object_name %>[priority]"
                     data-custom-select-target="hiddenInput"
                     value="<%= list_item.priority || 'medium' %>">
            </div>
          </div>
        </div>
        <!-- Due Date -->
        <div data-controller="calendar-collision">
          <%= f.label :due_date, class: "form-label" do %>
            Due Date
            <span class="text-xs text-ink-muted font-normal">(optional)</span>
          <% end %>
          <%= f.datetime_local_field :due_date,
                                     class: "form-input",
                                     data: {
                                       controller: "flatpickr",
                                       flatpickr_options_value: {
                                         enableTime: true,
                                         dateFormat: "Y-m-d H:i",
                                         time_24hr: false,
                                         minuteIncrement: 15
                                       }.to_json,
                                       calendar_collision_target: "dueDateInput",
                                       action: "change->calendar-collision#check"
                                     } %>
          <div data-calendar-collision-target="collisionWarning"></div>
        </div>
      </div>
      <!-- Recurrence Fields -->
      <%= render 'list_items/recurrence_fields', form_object: f, item: list_item %>
    </div>
    <!-- Toggle options button -->
    <div class="text-center">
      <button type="button"
              data-action="click->quick-add#toggleOptions"
        class="text-sm text-ink-muted hover:text-accent flex items-center space-x-1 mx-auto transition-colors duration-200">
        <span data-quick-add-target="optionsText">More options</span>
        <svg data-quick-add-target="optionsIcon" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
    </div>
  <% end %>
</div>