<!-- app/views/list_items/_recurrence_fields.html.erb -->
<div data-controller="recurrence" class="space-y-3">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= form_object.label :recurrence_rule, "Recurrence", class: "form-label" %>
      <%= form_object.select :recurrence_rule,
          options_for_select([
            ["Does not repeat", "none"],
            ["Daily", "daily"],
            ["Weekly", "weekly"],
            ["Every 2 weeks", "biweekly"],
            ["Monthly", "monthly"],
            ["Yearly", "yearly"]
          ], item.recurrence_rule || "none"),
          {},
          class: "form-input",
          data: { "recurrence-target": "ruleSelect", action: "change->recurrence#ruleChanged" } %>
    </div>
    <div data-recurrence-target="endDateWrapper"
         class="<%= item.recurrence_rule.blank? || item.recurrence_rule == 'none' ? 'hidden' : '' %>">
      <%= form_object.label :recurrence_end_date, class: "form-label" do %>
        End Date <span class="text-xs text-ink-muted font-normal">(optional)</span>
      <% end %>
      <%= form_object.datetime_local_field :recurrence_end_date,
          value: item.recurrence_end_date&.strftime("%Y-%m-%dT%H:%M"),
          class: "form-input" %>
    </div>
  </div>
</div>
