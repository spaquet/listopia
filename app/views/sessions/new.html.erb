<!-- app/views/sessions/new.html.erb -->
<div class="min-h-screen flex items-center justify-center bg-surface py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div>
      <div class="mx-auto h-12 w-12 bg-accent rounded-lg flex items-center justify-center">
        <span class="text-ink-inverse font-bold text-xl">L</span>
      </div>
      <h2 class="mt-6 text-center t-display-m text-ink">
        Welcome back
      </h2>
      <p class="mt-2 text-center t-body-s text-ink-muted">
        Sign in to your Listopia account
      </p>
    </div>
    <div class="card">
      <div class="card-body space-y-6">
        <%= form_with url: session_path,
                      data: { turbo: false },
                      class: "space-y-6" do |f| %>
          <% if flash[:alert] %>
            <div class="alert alert-danger">
              <%= flash[:alert] %>
            </div>
          <% end %>
          <div>
            <%= f.label :email, "Email address", class: "form-label" %>
            <%= f.email_field :email,
                              required: true,
                              autofocus: true,
                              autocomplete: "email",
                              class: "form-input" %>
          </div>
          <div>
            <%= f.label :password, "Password", class: "form-label" %>
            <%= f.password_field :password,
                                 required: true,
                                 autocomplete: "current-password",
                                 class: "form-input" %>
          </div>
          <div>
            <%= f.submit "Sign In", class: "w-full btn btn-primary" %>
          </div>
        <% end %>
        <!-- Magic Link Option -->
        <div class="mt-6">
          <div class="relative">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-rule"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-2 bg-surface text-ink-muted">Or</span>
            </div>
          </div>
          <%= form_with url: magic_link_path,
                      data: { turbo: false },
                      class: "mt-6" do |f| %>
            <div class="flex space-x-2">
              <%= f.email_field :email,
                              placeholder: "Enter your email for magic link",
                              class: "flex-1 form-input" %>
              <%= f.submit "Send Magic Link", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
        <div class="text-center mt-6">
          <p class="t-body-s text-ink-muted">
            Don't have an account?
            <%= link_to "Sign up here", new_registration_path,
                      class: "font-medium text-accent hover:text-accent transition-colors duration-200" %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>