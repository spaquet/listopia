<!-- app/views/comments/_form.html.erb -->
<!-- Form to add a new comment to a commentable resource -->
<% if user_signed_in? %>
  <%= turbo_frame_tag "new_comment_form_#{commentable.class.name.downcase}_#{commentable.id}" do %>
    <%
      # Determine the correct comment path based on commentable type
      comment_path = if commentable.is_a?(ListItem)
                       list_list_item_comments_path(commentable.list, commentable)
                     elsif commentable.is_a?(List)
                       list_comments_path(commentable)
                     end
    %>
    <%= form_with url: comment_path,
                   method: :post,
                   data: { turbo: true },
                   local: true,
                   class: "flex flex-col gap-2" do |f| %>
      <!-- Error Messages -->
      <% if comment.errors.any? %>
        <div class="alert alert-danger">
          <div class="alert-icon">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <div class="alert-content">
            <% comment.errors.full_messages.each do |message| %>
              <p class="alert-message"><%= message %></p>
            <% end %>
          </div>
        </div>
      <% end %>
      <!-- Comment Content Field -->
      <div>
        <%= text_area_tag "comment[content]",
                          comment.content,
                          rows: 3,
                          placeholder: "Add a comment...",
                          class: "form-input" %>
        <p class="mt-1 text-xs text-ink-muted">Markdown formatting is supported</p>
      </div>
      <!-- Submit Button -->
      <div class="flex justify-end">
        <%= submit_tag "Comment", class: "btn btn-primary btn-sm" %>
      </div>
    <% end %>
  <% end %>
<% else %>
  <!-- Login Prompt for Unauthenticated Users -->
  <div class="alert alert-info">
    <div class="alert-content">
      <p class="alert-message">
        <%= link_to "Sign in", new_session_path, class: "text-accent font-medium hover:text-accent" %>
        to add a comment
      </p>
    </div>
  </div>
<% end %>