<div class="min-h-screen bg-surface-raised py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="t-display-m text-ink">Compliance Report</h1>
        <p class="mt-2 text-ink-muted">Regulatory audit trail and change tracking</p>
      </div>
      <%= link_to "← Back to Audit", admin_audit_index_path, class: "px-4 py-2 bg-surface-raised hover:bg-surface-raised rounded-lg text-sm font-medium transition-colors" %>
    </div>

    <!-- Organization Context -->
    <div class="mb-6 bg-surface rounded-lg shadow p-4">
      <p class="t-meta text-ink-muted">Organization</p>
      <p class="text-xl font-semibold text-ink"><%= @organization.name %></p>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-surface rounded-lg shadow p-6">
        <div class="t-meta text-ink-muted">Total Events</div>
        <div class="t-display-m text-ink"><%= @html_report[:summary][:total_events] %></div>
      </div>

      <div class="bg-surface rounded-lg shadow p-6">
        <div class="t-meta text-ink-muted">Sensitive Changes</div>
        <div class="text-3xl font-bold text-warning"><%= @html_report[:summary][:sensitive_changes] %></div>
      </div>

      <div class="bg-surface rounded-lg shadow p-6">
        <div class="t-meta text-ink-muted">Critical Actions</div>
        <div class="text-3xl font-bold text-danger"><%= @html_report[:summary][:critical_actions] %></div>
      </div>

      <div class="bg-surface rounded-lg shadow p-6">
        <div class="t-meta text-ink-muted">Active Users</div>
        <div class="t-display-m text-ink"><%= @html_report[:summary][:unique_users] %></div>
      </div>
    </div>

    <!-- Risk Assessment -->
    <div class="bg-surface rounded-lg shadow p-6 mb-8">
      <h2 class="t-body-l font-semibold text-ink mb-4">Risk Assessment</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="border-l-4 border-danger pl-4">
          <div class="t-meta text-ink-muted">Bulk Deletions</div>
          <div class="t-display-s text-ink"><%= @html_report[:risk_assessment][:high_risk][:bulk_deletions] ? '⚠️ Yes' : '✅ No' %></div>
        </div>
        <div class="border-l-4 border-warning pl-4">
          <div class="t-meta text-ink-muted">Access Changes</div>
          <div class="t-display-s text-ink"><%= @html_report[:risk_assessment][:high_risk][:access_changes] %></div>
        </div>
        <div class="border-l-4 border-warning pl-4">
          <div class="t-meta text-ink-muted">Ownership Changes</div>
          <div class="t-display-s text-ink"><%= @html_report[:risk_assessment][:high_risk][:ownership_changes] %></div>
        </div>
      </div>

      <% if @html_report[:risk_assessment][:anomalies].any? %>
        <div class="mt-4 pt-4 border-t border-rule">
          <div class="text-sm font-medium text-danger">Anomalies Detected:</div>
          <ul class="mt-2 space-y-1">
            <% @html_report[:risk_assessment][:anomalies].each do |anomaly| %>
              <li class="text-sm text-ink">• <%= anomaly %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <!-- Export Options -->
    <div class="bg-surface rounded-lg shadow p-6 mb-8">
      <h2 class="t-body-l font-semibold text-ink mb-4">Export Report</h2>
      <div class="flex gap-3">
        <%= link_to compliance_report_admin_audit_index_path(format: :csv), class: "btn btn-primary inline-flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
          </svg>
          Download CSV
        <% end %>
        <%= link_to compliance_report_admin_audit_index_path(format: :json), class: "btn btn-primary inline-flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
          </svg>
          Download JSON
        <% end %>
      </div>
    </div>

    <!-- Sensitive Changes Table -->
    <% if @html_report[:sensitive_changes].any? %>
      <div class="bg-surface rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-rule">
          <h2 class="t-body-l font-semibold text-ink">Sensitive Field Changes</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-surface-raised border-b border-rule">
              <tr>
                <th class="px-6 py-3 text-left text-sm font-semibold text-ink">Timestamp</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-ink">User</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-ink">Event</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-ink">Details</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-rule">
              <% @html_report[:sensitive_changes].first(50).each do |event| %>
                <tr class="hover:bg-surface-raised">
                  <td class="px-6 py-3 t-meta text-ink-muted"><%= event["created_at"] %></td>
                  <td class="px-6 py-3 text-sm text-ink"><%= event["actor_id"] || "System" %></td>
                  <td class="px-6 py-3 text-sm"><span class="pill warning"><%= event["event_type"] %></span></td>
                  <td class="px-6 py-3 t-meta text-ink-muted"><%= event["event_data"]&.to_s&.truncate(80) || "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  </div>
</div>
