<div class="min-h-screen bg-surface-raised py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="t-display-m text-ink">User Activity Log</h1>
        <p class="mt-2 text-ink-muted">Track individual user actions and changes</p>
      </div>
      <%= link_to "← Back to Audit", admin_audit_index_path, class: "px-4 py-2 bg-surface-raised hover:bg-surface-raised rounded-lg text-sm font-medium transition-colors" %>
    </div>

    <!-- Organization Context -->
    <div class="mb-6 bg-surface rounded-lg shadow p-4">
      <p class="t-meta text-ink-muted">Organization</p>
      <p class="text-xl font-semibold text-ink"><%= @organization.name %></p>
    </div>

    <% if @user %>
      <!-- User Activity Summary -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <div class="bg-surface rounded-lg shadow p-6">
          <div class="t-meta text-ink-muted">Total Events</div>
          <div class="t-display-m text-ink"><%= @summary[:total_events] %></div>
        </div>

        <div class="bg-surface rounded-lg shadow p-6">
          <div class="t-meta text-ink-muted">Event Types</div>
          <div class="t-display-m text-ink"><%= @summary[:events_by_type]&.keys&.count || 0 %></div>
        </div>

        <div class="bg-surface rounded-lg shadow p-6">
          <div class="t-meta text-ink-muted">User</div>
          <div class="t-body-l font-semibold text-ink"><%= @user.email %></div>
        </div>
      </div>

      <!-- Activity Timeline -->
      <div class="bg-surface rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-rule">
          <h2 class="t-body-l font-semibold text-ink">Activity Timeline</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-surface-raised border-b border-rule">
              <tr>
                <th class="px-6 py-3 text-left text-sm font-semibold text-ink">Timestamp</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-ink">Event Type</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-ink">Details</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-rule">
              <% @events.each do |event| %>
                <tr class="hover:bg-surface-raised">
                  <td class="px-6 py-3 t-meta text-ink-muted"><%= event.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
                  <td class="px-6 py-3 text-sm text-ink"><span class="inline-block bg-surface-raised text-accent px-2 py-1 rounded text-xs font-medium"><%= event.event_type %></span></td>
                  <td class="px-6 py-3 t-meta text-ink-muted">
                    <% case event.event_type %>
                      <% when "list_item.created" %>
                        Created: <%= event.event_data["title"] %>
                      <% when "list_item.deleted" %>
                        Deleted: <%= event.event_data["title"] %>
                      <% when "list_item.assigned" %>
                        Assigned to user
                      <% when "list_item.status_changed" %>
                        <%= event.event_data["from"] %> → <%= event.event_data["to"] %>
                      <% else %>
                        <%= event.event_type %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <!-- Select User -->
      <div class="bg-surface rounded-lg shadow p-6">
        <h2 class="t-body-l font-semibold text-ink mb-4">Select User</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @users.each do |user| %>
            <%= link_to activity_log_admin_audit_index_path(user_id: user.id), class: "block p-4 card hover:border-accent transition-colors" do %>
              <div class="font-medium text-ink"><%= user.name %></div>
              <div class="t-meta text-ink-muted"><%= user.email %></div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
