<!-- app/views/admin/users/show.html.erb -->
<div class="max-w-4xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= user_avatar_initials(@user, size: 'w-16 h-16 text-xl') %>
      <div>
        <h1 class="t-display-m text-ink"><%= @user.name %></h1>
        <p class="text-ink-muted"><%= @user.email %></p>
      </div>
    </div>
    <div class="flex items-center space-x-3">
      <%= link_to admin_users_path, class: "text-ink-muted hover:text-ink px-4 py-2 rounded-lg border border-rule hover:border-rule transition-colors duration-fast" do %>
        Back to Users
      <% end %>
      <%= link_to edit_admin_user_path(@user), class: "btn btn-primary transition-colors duration-fast" do %>
        Edit User
      <% end %>
    </div>
  </div>
  <div class="bg-surface card border-rule divide-y divide-gray-200">
    <div class="p-6">
      <h2 class="t-body-l font-semibold text-ink mb-4">User Information</h2>
      <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <dt class="text-sm font-medium text-ink-muted">Full Name</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Email</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.email %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Status</dt>
          <dd class="mt-1">
            <% if @user.active? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-raised text-ink">Active</span>
            <% elsif @user.suspended? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-raised text-ink">Suspended</span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-raised text-gray-800"><%= @user.status.titleize %></span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Role</dt>
          <dd class="mt-1">
            <% if @user.admin? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Admin</span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-raised text-gray-800">User</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Email Verified</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.email_verified? ? '✓ Yes' : '✗ No' %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Locale</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.locale %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Timezone</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.timezone %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Joined</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.created_at.strftime('%B %d, %Y') %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Last Sign In</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.last_sign_in_at ? @user.last_sign_in_at.strftime('%B %d, %Y at %H:%M') : 'Never' %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Sign In Count</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.sign_in_count %></dd>
        </div>
      </dl>
      <% if @user.bio.present? %>
        <div class="mt-4">
          <dt class="text-sm font-medium text-ink-muted">Bio</dt>
          <dd class="mt-1 text-sm text-ink"><%= @user.bio %></dd>
        </div>
      <% end %>
    </div>
    <div class="p-6">
      <h2 class="t-body-l font-semibold text-ink mb-4">Activity</h2>
      <dl class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <dt class="text-sm font-medium text-ink-muted">Lists Created</dt>
          <dd class="mt-1 text-2xl font-semibold text-ink"><%= @user.lists.count %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Collaborations</dt>
          <dd class="mt-1 text-2xl font-semibold text-ink"><%= @user.collaborators.where(collaboratable_type: "List").count %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-ink-muted">Messages</dt>
          <dd class="mt-1 text-2xl font-semibold text-ink"><%= @user.messages.count %></dd>
        </div>
      </dl>
    </div>
  </div>
  <% unless @user == current_user %>
    <div class="bg-surface card border-rule p-6">
      <h2 class="t-body-l font-semibold text-ink mb-4">Admin Actions</h2>
      <div class="flex flex-wrap gap-3">
        <%= button_to toggle_admin_admin_user_path(@user), method: :post,
                      class: "px-4 py-2 rounded-lg border transition-colors duration-fast #{@user.admin? ? 'border-red-300 text-danger hover:alert alert-danger' : 'border-purple-300 text-purple-600 hover:bg-purple-50'}" do %>
          <%= @user.admin? ? 'Revoke Admin' : 'Grant Admin' %>
        <% end %>
        <%= button_to toggle_status_admin_user_path(@user), method: :post,
                      class: "px-4 py-2 rounded-lg border transition-colors duration-fast #{@user.suspended? ? 'border-green-300 text-success hover:alert alert-success' : 'border-red-300 text-danger hover:alert alert-danger'}" do %>
          <%= @user.suspended? ? 'Reactivate User' : 'Suspend User' %>
        <% end %>
      </div>
    </div>
  <% end %>
  <% unless @user == current_user %>
    <div class="bg-surface card border-red-200 p-6">
      <h2 class="text-lg font-semibold text-ink mb-4">Danger Zone</h2>
      <div class="flex items-center justify-between p-4 alert alert-danger rounded-lg">
        <div>
          <h3 class="text-sm font-medium text-ink">Delete User</h3>
          <p class="text-sm text-danger">Permanently delete this user and all their data</p>
        </div>
        <%= button_to 'Delete User', admin_user_path(@user), 
                      method: :delete,
                      data: { turbo_confirm: 'Are you sure? This action cannot be undone.' },
                      class: "btn btn-danger transition-colors duration-fast" %>
      </div>
    </div>
  <% end %>
</div>