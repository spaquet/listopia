<!-- app/views/admin/users/_form.html.erb -->
<%= form_with model: [:admin, @user], local: true, class: "space-y-6" do |f| %>
  <% if @organization_id.present? %>
    <%= hidden_field_tag :organization_id, @organization_id %>
  <% end %>
  <div>
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, 
                     class: "form-input",
                     placeholder: "Full name" %>
    <% if @user.errors[:name].any? %>
      <p class="mt-1 text-sm text-danger"><%= @user.errors[:name].first %></p>
    <% end %>
  </div>
  <div>
    <%= f.label :email, class: "form-label" %>
    <%= f.email_field :email, 
                      class: "form-input",
                      placeholder: "email@example.com" %>
    <% if @user.errors[:email].any? %>
      <p class="mt-1 text-sm text-danger"><%= @user.errors[:email].first %></p>
    <% end %>
  </div>
  <% if @user.new_record? %>
    <!-- Admin Setup Info -->
    <div class="alert alert-info mb-6">
      <h3 class="text-sm font-medium text-ink mb-2">Password Setup</h3>
      <p class="text-sm text-accent">
        An invitation email with a password setup link will be sent to the user after creation. 
        They will set their own password when they verify their email.
      </p>
    </div>
    <!-- Admin Role -->
    <div class="flex items-center mb-6">
      <%= check_box_tag 'user[make_admin]', '1', false, class: "h-4 w-4 text-accent focus:ring-accent border-rule rounded" %>
      <%= label_tag 'user[make_admin]', "Grant admin privileges", class: "ml-2 text-sm text-ink" %>
    </div>
  <% end %>
  <div>
    <%= f.label :bio, "About", class: "form-label" %>
    <%= f.text_area :bio, 
                    rows: 4,
                    class: "form-input",
                    placeholder: "Brief description..." %>
  </div>
  <div>
    <%= f.label :locale, "Language", class: "form-label" %>
    <%= f.select :locale, 
                 locale_options,
                 {},
                 class: "form-input" %>
  </div>
  <div>
    <%= f.label :timezone, "Time Zone", class: "form-label" %>
    <%= f.select :timezone, 
                 timezone_options,
                 {},
                 class: "form-input" %>
  </div>
  <div>
    <%= f.label :admin_notes, "Admin Notes (Internal)", class: "form-label" %>
    <%= f.text_area :admin_notes, 
                    rows: 3,
                    class: "form-input",
                    placeholder: "Internal notes about this user..." %>
    <p class="mt-1 t-meta text-ink-muted">These notes are only visible to admins</p>
  </div>
  <div class="flex items-center justify-between pt-4">
    <% cancel_path = @user.new_record? ?
                     admin_users_path(organization_id: @organization_id) :
                     admin_user_path(@user) %>
    <%= link_to "Cancel", cancel_path, class: "text-ink-muted hover:text-ink font-medium" %>
    <%= f.submit @user.new_record? ? "Create User" : "Update User",
                 class: "btn btn-primary transition-colors duration-fast font-medium" %>
  </div>
<% end %>