<div class="max-w-6xl mx-auto p-6">
  <div class="bg-surface card border-rule">
    <div class="px-6 py-4 border-b border-rule">
      <h2 class="text-xl font-semibold text-ink">Organization Members</h2>
      <p class="text-sm text-ink-muted mt-1"><%= @organization.name %></p>
    </div>

    <div class="px-6 py-4">
      <% if @members.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead>
              <tr class="border-b border-rule">
                <th class="px-4 py-2 text-left text-xs font-medium text-ink-muted uppercase">User</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-ink-muted uppercase">Role</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-ink-muted uppercase">Status</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-ink-muted uppercase">Joined At</th>
              </tr>
            </thead>
            <tbody>
              <% @members.each do |membership| %>
                <tr class="border-b border-rule hover:bg-surface-raised">
                  <td class="px-4 py-2 text-sm text-ink"><%= membership.user.email %></td>
                  <td class="px-4 py-2 t-meta text-ink-muted capitalize"><%= membership.role %></td>
                  <td class="px-4 py-2 t-meta text-ink-muted capitalize"><%= membership.status %></td>
                  <td class="px-4 py-2 t-meta text-ink-muted"><%= membership.joined_at.strftime('%b %d, %Y') %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <% if @pagy && @pagy.pages > 1 %>
          <div class="mt-6 flex justify-center">
            <p class="text-ink-muted">Page <%= @pagy.page %> of <%= @pagy.pages %></p>
          </div>
        <% end %>
      <% else %>
        <p class="t-meta text-ink-muted">No members found</p>
      <% end %>
    </div>
  </div>
</div>
