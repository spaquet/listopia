<div class="max-w-7xl mx-auto space-y-6">
  <div>
    <h1 class="t-display-m text-ink">Lists</h1>
    <p class="text-ink-muted mt-1">View and manage all lists in the system</p>
  </div>

  <% if @lists.any? %>
    <div class="card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead class="bg-surface-raised border-b border-rule">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold text-ink uppercase tracking-wider">Title</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-ink uppercase tracking-wider">Owner</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-ink uppercase tracking-wider">Created At</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-ink uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-rule">
            <% @lists.each do |list| %>
              <tr class="hover:bg-surface-raised transition-colors">
                <td class="px-6 py-4 text-sm font-medium text-ink">
                  <%= link_to list.title, admin_list_path(list), class: "text-accent hover:text-accent" %>
                </td>
                <td class="px-6 py-4 text-sm text-ink-muted">
                  <%= list.owner&.email %>
                </td>
                <td class="px-6 py-4 text-sm text-ink-muted">
                  <%= list.created_at.strftime("%B %d, %Y") %>
                </td>
                <td class="px-6 py-4 text-right text-sm space-x-2 flex justify-end">
                  <%= link_to "Show", admin_list_path(list), class: "text-accent hover:text-accent" %>
                  <%= link_to "Delete", admin_list_path(list), method: :delete, data: { confirm: "Are you sure?" }, class: "text-danger hover:text-danger" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <svg class="mx-auto h-12 w-12 text-ink-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
      </svg>
      <p class="mt-4 t-meta text-ink-muted">No lists found.</p>
    </div>
  <% end %>
</div>
