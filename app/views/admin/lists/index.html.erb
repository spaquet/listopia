<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-8">Lists</h1>

  <% if @lists.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full border border-rule">
        <thead class="bg-surface-raised">
          <tr>
            <th class="border border-rule px-4 py-2 text-left">Title</th>
            <th class="border border-rule px-4 py-2 text-left">Owner</th>
            <th class="border border-rule px-4 py-2 text-left">Created At</th>
            <th class="border border-rule px-4 py-2 text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @lists.each do |list| %>
            <tr class="hover:bg-surface-raised">
              <td class="border border-rule px-4 py-2">
                <%= link_to list.title, admin_list_path(list), class: "text-accent hover:underline" %>
              </td>
              <td class="border border-rule px-4 py-2">
                <%= list.owner&.email %>
              </td>
              <td class="border border-rule px-4 py-2">
                <%= list.created_at.strftime("%B %d, %Y") %>
              </td>
              <td class="border border-rule px-4 py-2 text-center">
                <%= link_to "Show", admin_list_path(list), class: "text-accent hover:underline mr-3" %>
                <%= link_to "Delete", admin_list_path(list), method: :delete, data: { confirm: "Are you sure?" }, class: "text-danger hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-ink-muted">No lists found.</p>
  <% end %>
</div>
