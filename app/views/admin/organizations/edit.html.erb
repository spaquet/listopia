<div class="space-y-6 max-w-2xl">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="t-display-m text-ink">Edit Organization</h1>
      <p class="mt-2 text-ink-muted">Update settings for <%= @organization.name %></p>
    </div>
    <%= link_to "← Back", admin_organization_path(@organization), class: "px-4 py-2 bg-surface-raised hover:bg-surface-raised rounded-lg" %>
  </div>

  <div class="bg-surface rounded-lg border border-rule p-6">
    <%= render "form", organization: @organization %>
  </div>
</div>
