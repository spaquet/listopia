<div class="modal-backdrop" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <div class="modal-content w-full max-w-lg">
    <!-- Header -->
    <div class="modal-header">
      <h3 id="modal-title">Create Organization</h3>
      <button type="button" class="modal-close" onclick="document.getElementById('admin_modals').innerHTML = ''">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Form -->
    <div class="modal-body">
      <%= form_with model: [:admin, organization], local: true, class: "space-y-4" do |f| %>
        <% if organization.errors.any? %>
          <div class="alert alert-danger">
            <h3 class="text-sm font-medium text-ink mb-2">
              <%= pluralize(organization.errors.count, "error") %> prevented this organization from being saved:
            </h3>
            <ul class="text-sm text-danger list-disc list-inside">
              <% organization.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "Organization Name", class: "form-label" %>
          <%= f.text_field :name,
            class: "form-input",
            placeholder: "My Organization",
            required: true,
            autofocus: true
          %>
          <p class="mt-1 t-meta text-ink-muted">The name of your organization</p>
        </div>

        <div>
          <%= f.label :size, "Organization Size", class: "form-label" %>
          <%= f.select :size,
            [["Small (1-10 members)", "small"], ["Medium (11-50 members)", "medium"], ["Large (51-200 members)", "large"], ["Enterprise (200+ members)", "enterprise"]],
            { selected: organization.size || "small" },
            class: "form-input"
          %>
          <p class="mt-1 t-meta text-ink-muted">Helps us provide the right support for your organization</p>
        </div>

        <!-- Footer -->
        <div class="mt-6 flex gap-3">
          <%= f.submit "Create Organization", class: "btn btn-primary flex-1" %>
          <button type="button" class="btn btn-secondary flex-1" onclick="document.getElementById('admin_modals').innerHTML = ''">
            Cancel
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
