<%= form_with model: [:admin, @organization], local: true, class: "space-y-6" do |f| %>
  <% if @organization.errors.any? %>
    <div class="alert alert-danger">
      <h3 class="text-sm font-medium text-ink mb-2">
        <%= pluralize(@organization.errors.count, "error") %> prevented this organization from being saved:
      </h3>
      <ul class="text-sm text-danger list-disc list-inside">
        <% @organization.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Organization Name", class: "form-label" %>
    <%= f.text_field :name,
      class: "form-input",
      placeholder: "My Organization",
      required: true
    %>
    <p class="mt-1 t-meta text-ink-muted">The name of your organization</p>
  </div>

  <div>
    <%= f.label :size, "Organization Size", class: "form-label" %>
    <%= f.select :size,
      [["Small (1-10 members)", "small"], ["Medium (11-50 members)", "medium"], ["Large (51-200 members)", "large"], ["Enterprise (200+ members)", "enterprise"]],
      { selected: @organization.size || "small" },
      class: "form-input"
    %>
    <p class="mt-1 t-meta text-ink-muted">Helps us provide the right support for your organization</p>
  </div>

  <div class="flex gap-2">
    <%= f.submit @organization.persisted? ? "Update Organization" : "Create Organization",
      class: "btn btn-primary"
    %>
    <%= link_to "Cancel",
      @organization.persisted? ? admin_organization_path(@organization) : admin_organizations_path,
      class: "btn btn-secondary"
    %>
  </div>
<% end %>
