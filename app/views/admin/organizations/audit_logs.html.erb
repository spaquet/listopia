<div class="max-w-6xl mx-auto p-6">
  <div class="bg-surface card border-rule">
    <div class="px-6 py-4 border-b border-rule">
      <h2 class="text-xl font-semibold text-ink">Audit Logs</h2>
      <p class="text-sm text-ink-muted mt-1"><%= @organization.name %></p>
    </div>

    <div class="px-6 py-4">
      <% if @audits.any? %>
        <div class="space-y-4">
          <% @audits.each do |audit| %>
            <div class="border-b pb-4">
              <p class="text-sm font-medium text-ink"><%= audit.class %></p>
              <p class="t-meta text-ink-muted"><%= audit.created_at.strftime('%b %d, %Y %H:%M:%S') %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="t-meta text-ink-muted">No audit logs available</p>
      <% end %>
    </div>
  </div>
</div>
