<div id="agent_card_<%= agent.id %>" class="card group relative overflow-hidden flex flex-col h-full">
  <!-- Rating badge (top right) -->
  <% if agent.average_rating.present? %>
    <div class="absolute top-4 right-4 z-10">
      <div class="pill accent text-2xs flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
        </svg>
        <span><%= number_with_precision(agent.average_rating, precision: 1) %></span>
      </div>
    </div>
  <% end %>

  <!-- Agent scope badge (top left) -->
  <div class="absolute top-4 left-4 z-10">
    <span class="pill t-2xs">
      <%= agent.scope.titleize %>
    </span>
  </div>

  <!-- Clickable card content -->
  <%= link_to ai_agent_path(agent), class: "flex flex-col flex-1 px-6 pt-12 pb-6" do %>
    <!-- Title -->
    <div class="mb-3 shrink-0">
      <h3 class="t-body-l font-semibold text-ink truncate group-hover:text-accent transition-colors duration-base">
        <%= agent.name %>
      </h3>
      <% if agent.description.present? %>
        <p class="mt-1 t-body-s text-ink-muted line-clamp-2">
          <%= agent.description %>
        </p>
      <% else %>
        <p class="mt-1 t-body-s text-ink-muted h-10"></p>
      <% end %>
    </div>

    <!-- Tags -->
    <% if agent.tags.any? %>
      <div class="flex flex-wrap gap-2 mb-4 shrink-0">
        <% agent.tags.each do |tag| %>
          <span class="pill t-2xs">
            <%= tag.name %>
          </span>
        <% end %>
      </div>
    <% else %>
      <div class="mb-4 shrink-0 h-6"></div>
    <% end %>

    <!-- Stats row -->
    <div class="grow"></div>
    <div class="flex items-center justify-between t-meta text-ink-subtle shrink-0">
      <span><%= pluralize(agent.run_count, 'run') %></span>
    </div>
  <% end %>
</div>
