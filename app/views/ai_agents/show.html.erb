<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900"><%= @agent.name %></h1>
          <p class="text-gray-600 mt-1"><%= @agent.scope.titleize %> Agent</p>
        </div>
        <% if policy(@agent).edit? %>
          <div class="flex gap-2">
            <%= link_to "Edit", edit_ai_agent_path(@agent), class: "bg-gray-100 hover:bg-gray-200 text-gray-700 py-2 px-4 rounded transition" %>
            <%= link_to "Delete", ai_agent_path(@agent), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-100 hover:bg-red-200 text-red-700 py-2 px-4 rounded transition" %>
          </div>
        <% end %>
      </div>

      <p class="text-gray-700 mb-4"><%= @agent.description %></p>

      <div class="grid grid-cols-3 gap-4 py-4 border-t border-b border-gray-200">
        <div>
          <p class="text-xs text-gray-600">Runs</p>
          <p class="text-2xl font-bold text-gray-900"><%= @agent.run_count %></p>
        </div>
        <div>
          <p class="text-xs text-gray-600">Success Rate</p>
          <p class="text-2xl font-bold text-green-600"><%= @agent.run_count > 0 ? number_with_precision(@agent.success_count * 100.0 / @agent.run_count, precision: 0) : 0 %>%</p>
        </div>
        <div>
          <p class="text-xs text-gray-600">Rating</p>
          <p class="text-2xl font-bold text-yellow-600"><%= @agent.average_rating.present? ? number_with_precision(@agent.average_rating, precision: 1) : "—" %></p>
        </div>
      </div>

      <% if policy(@agent).invoke? %>
        <div class="mt-6 p-4 bg-blue-50 rounded-lg">
          <h3 class="font-semibold text-gray-900 mb-3">Run Agent</h3>
          <%= form_with url: invoke_ai_agent_path(@agent), method: :post, local: true, class: "space-y-3" do |f| %>
            <%= f.text_area :user_input, placeholder: "What would you like this agent to do?", class: "w-full border border-gray-300 rounded p-2 text-sm", rows: 3 %>
            <%= f.submit "Invoke Agent", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded w-full transition" %>
          <% end %>
        </div>
      <% end %>

      <% params_hash = @agent.parameters.is_a?(String) ? (JSON.parse(@agent.parameters) rescue {}) : (@agent.parameters || {}) %>
      <% if params_hash.present? && params_hash.is_a?(Hash) %>
        <div class="mt-6">
          <h3 class="font-semibold text-gray-900 mb-3">Input Parameters</h3>
          <div class="space-y-2 text-sm">
            <% params_hash.each do |key, description| %>
              <div class="p-2 bg-gray-50 border border-gray-200 rounded">
                <span class="font-mono text-gray-900"><%= key %></span>
                <% if description.is_a?(String) && description.present? %>
                  <p class="text-gray-600"><%= description %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Resources & Tools</h2>
          <p class="text-xs text-gray-600 mt-1">Resources define what tools this agent can use at runtime</p>
        </div>
        <% if policy(@agent).edit? %>
          <%= link_to "Add Resource", new_ai_agent_ai_agent_resource_path(@agent), data: { turbo_frame: "resource_form" }, class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded text-sm transition" %>
        <% end %>
      </div>

      <%= turbo_frame_tag "resource_form" %>

      <% if @agent.ai_agent_resources.any? %>
        <div id="agent_resources_list" class="space-y-2">
          <% @agent.ai_agent_resources.each do |resource| %>
            <%= render "ai_agent_resources/resource", resource: resource, agent: @agent %>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-600 text-center py-4">No resources configured. Add resources to enable tools.</p>
      <% end %>
    </div>

    <!-- Instructions Section -->
    <% if @agent.instructions.present? %>
      <div class="bg-white rounded-lg shadow p-6 mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Instructions (Step-by-Step SOP)</h2>
        <div class="text-gray-700 whitespace-pre-wrap text-sm bg-gray-50 p-4 rounded border border-gray-200"><%= @agent.instructions %></div>
      </div>
    <% end %>

    <!-- Trigger Configuration -->
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">Trigger Configuration</h2>
      <% trigger_config = @agent.trigger_config || { "type" => "manual" } %>
      <% trigger_type = trigger_config["type"] || "manual" %>

      <div class="space-y-3">
        <div class="flex items-center">
          <span class="text-sm font-semibold text-gray-700 min-w-24">Type:</span>
          <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold <%= case trigger_type
            when "event" then "bg-purple-100 text-purple-800"
            when "schedule" then "bg-blue-100 text-blue-800"
            else "bg-gray-100 text-gray-800"
            end %>"><%= trigger_type.titleize %></span>
        </div>

        <% if trigger_type == "event" %>
          <div class="flex items-center">
            <span class="text-sm font-semibold text-gray-700 min-w-24">Event:</span>
            <span class="text-sm text-gray-600"><code class="bg-gray-100 px-2 py-1 rounded"><%= trigger_config['event_type'] %></code></span>
          </div>
        <% elsif trigger_type == "schedule" %>
          <div class="flex items-center">
            <span class="text-sm font-semibold text-gray-700 min-w-24">Cron:</span>
            <span class="text-sm text-gray-600"><code class="bg-gray-100 px-2 py-1 rounded"><%= trigger_config['cron'] %></code></span>
          </div>
        <% end %>

        <% if @agent.pre_run_questions.present? && @agent.pre_run_questions.any? %>
          <div class="mt-3 pt-3 border-t border-gray-200">
            <p class="text-sm font-semibold text-gray-700 mb-2">Pre-Run Questions:</p>
            <div class="space-y-2">
              <% @agent.pre_run_questions.each do |q| %>
                <div class="p-2 bg-gray-50 rounded text-sm">
                  <p class="font-semibold text-gray-900"><%= q["question"] %></p>
                  <p class="text-xs text-gray-600 mt-1">Required: <%= q["required"] ? "Yes" : "No" %></p>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Body Context Configuration -->
    <% if @agent.body_context_config.present? && @agent.body_context_config.any? %>
      <div class="bg-white rounded-lg shadow p-6 mb-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Auto-Loaded Context</h2>
        <div class="space-y-2 text-sm">
          <% if @agent.body_context_config["load"] == "invocable" %>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-600 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span class="text-gray-700"><strong>Invocable Resource</strong> — Loads the target list/item</span>
            </div>
          <% elsif @agent.body_context_config["load"] == "all_lists" %>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-600 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span class="text-gray-700"><strong>All Lists</strong> — Loads all organization lists</span>
            </div>
          <% elsif @agent.body_context_config["load"] == "recent_runs" %>
            <div class="flex items-center">
              <svg class="w-5 h-5 text-green-600 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              <span class="text-gray-700"><strong>Recent Runs</strong> — Loads summaries of last <%= @agent.body_context_config["limit"] || 5 %> runs</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Similar Agents (via embeddings) -->
    <% if @agent.embedding.present? %>
      <% similar_agents = @agent.similar_to(limit: 3) %>
      <% if similar_agents.any? %>
        <div class="bg-white rounded-lg shadow p-6 mb-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-3">Similar Agents (by embedding)</h2>
          <div class="space-y-2">
            <% similar_agents.each do |similar_agent| %>
              <div class="p-3 border border-gray-200 rounded hover:bg-gray-50 flex items-center justify-between">
                <div>
                  <p class="font-semibold text-gray-900"><%= link_to similar_agent.name, ai_agent_path(similar_agent), class: "text-blue-600 hover:text-blue-800" %></p>
                  <p class="text-sm text-gray-600"><%= similar_agent.description.truncate(80) %></p>
                </div>
                <span class="text-xs text-gray-500"><%= similar_agent.scope.titleize %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <!-- Recent Runs -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Recent Runs</h2>
      <% if @recent_runs.any? %>
        <div class="space-y-2">
          <% @recent_runs.each do |run| %>
            <div class="flex items-center justify-between p-3 border border-gray-200 rounded hover:bg-gray-50">
              <div class="flex-1">
                <p class="font-medium text-gray-900"><%= run.user_input.truncate(50) %></p>
                <p class="text-xs text-gray-500"><%= time_ago_in_words(run.created_at) %> ago</p>
              </div>
              <div class="text-right">
                <span class="px-2 py-1 text-xs font-semibold rounded <%= case run.status
                  when "running" then "bg-yellow-100 text-yellow-800"
                  when "completed" then "bg-green-100 text-green-800"
                  when "failed" then "bg-red-100 text-red-800"
                  else "bg-gray-100 text-gray-800"
                  end %>"><%= run.status.titleize %></span>
                <%= link_to "View", ai_agent_run_path(run), class: "ml-2 text-blue-600 hover:text-blue-800 text-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-600 text-center py-4">No runs yet</p>
      <% end %>
    </div>
  </div>
</div>
