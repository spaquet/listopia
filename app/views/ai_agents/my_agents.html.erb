<div class="container mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="t-display-s text-ink">Your Personal Agents</h1>
      <p class="mt-2 text-ink-muted">Create and manage custom AI agents</p>
    </div>
    <%= link_to "Create New Agent", new_ai_agent_path, class: "btn btn-primary" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @agents.each do |agent| %>
      <%= render "ai_agents/agent_card", agent: agent %>
    <% end %>
  </div>

  <% if @agents.empty? %>
    <div class="text-center py-12 bg-surface-raised rounded-lg border border-rule">
      <p class="text-ink-muted mb-4">You haven't created any personal agents yet</p>
      <%= link_to "Create your first agent", new_ai_agent_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
