<!-- app/views/dashboard/items_kanban.html.erb -->
<div class="space-y-6">
  <!-- Header Section -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="t-display-s text-ink">All Items Kanban</h1>
      <p class="text-ink-muted mt-1">Kanban view of all items from your active lists</p>
    </div>
    <%= link_to lists_path, class: "btn btn-secondary inline-flex items-center mt-4 sm:mt-0" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Lists
    <% end %>
  </div>

  <!-- Kanban Board -->
  <div class="overflow-x-auto pb-6" data-controller="kanban">
    <div class="flex gap-6 min-w-min">
      <% @column_names.each do |column_name| %>
        <div class="kanban-column">
          <!-- Column Header -->
          <div class="kanban-column-header">
            <h3 class="kanban-column-title">
              <%= column_name %>
              <span class="kanban-column-count">
                <%= @items_by_column[column_name]&.length || 0 %>
              </span>
            </h3>
          </div>

          <!-- Column Items -->
          <div class="kanban-column-items"
               id="column_<%= column_name.parameterize %>"
               data-column-name="<%= column_name %>"
               data-kanban-target="column">
            <% @items_by_column[column_name]&.each do |item| %>
              <div id="item_<%= item.id %>"
                   class="kanban-card"
                   data-item-id="<%= item.id %>"
                   data-list-id="<%= item.list.id %>"
                   data-kanban-target="card">

                <!-- Quick Actions (on hover) -->
                <div class="kanban-card-actions">
                  <!-- Edit -->
                  <%= link_to edit_list_list_item_path(item.list, item),
                              data: { turbo_frame: "modal" },
                              class: "kanban-card-action",
                              title: "Edit" do %>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  <% end %>

                  <!-- Delete -->
                  <% if can_access_list?(item.list, current_user, :edit) %>
                    <%= button_to list_list_item_path(item.list, item),
                                  method: :delete,
                                  data: { turbo_confirm: "Delete this item?" },
                                  class: "kanban-card-action delete",
                                  title: "Delete" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    <% end %>
                  <% end %>
                </div>

                <!-- List Badge -->
                <div class="kanban-card-badges mb-2">
                  <%= link_to list_path(item.list), class: "inline-block" do %>
                    <span class="pill accent"><%= item.list.title %></span>
                  <% end %>
                </div>

                <!-- Item Type Icon -->
                <div class="kanban-card-header">
                  <div class="kanban-card-type-icon">
                    <%= item_type_icon(item.item_type) %>
                  </div>
                  <span class="text-xs text-ink-subtle"><%= item.item_type.titleize.gsub('_', ' ') %></span>
                </div>

                <!-- Title -->
                <h4 class="kanban-card-title">
                  <%= link_to item.title, list_list_item_path(item.list, item), data: { turbo_frame: "modal" } %>
                </h4>

                <!-- Priority & Status badges -->
                <div class="kanban-card-badges">
                  <!-- Priority -->
                  <span class="kanban-card-badge <%= item.priority.downcase %>">
                    <%= item.priority.capitalize %>
                  </span>

                  <!-- Status -->
                  <% if item.status_completed? %>
                    <span class="kanban-card-badge completed">
                      ✓ Done
                    </span>
                  <% elsif item.status_in_progress? %>
                    <span class="kanban-card-badge in-progress">
                      In Progress
                    </span>
                  <% end %>
                </div>

                <!-- Meta Information -->
                <div class="kanban-card-meta">
                  <!-- Due Date (if present) -->
                  <% if item.due_date.present? %>
                    <div class="kanban-card-due-date <%= 'overdue' if item.due_date < Time.current && !item.status_completed? %>">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      <span><%= item.due_date.strftime("%b %d") %></span>
                    </div>
                  <% end %>

                  <!-- Assignee -->
                  <% if item.assigned_user.present? %>
                    <div class="kanban-card-assignee">
                      <div class="kanban-card-assignee-avatar">
                        <%= item.assigned_user.email[0].upcase %>
                      </div>
                      <span><%= format_assignee_name(item.assigned_user) %></span>
                    </div>
                  <% end %>
                </div>

                <!-- Completion Checkbox (if pending or in progress) -->
                <% if (item.status_pending? || item.status_in_progress?) && current_user && can_access_list?(item.list, current_user) %>
                  <%= button_to toggle_completion_list_list_item_path(item.list, item),
                                method: :patch,
                                data: { turbo_stream: true },
                                class: "kanban-card-action-button" do %>
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Mark Complete
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Empty State -->
  <% if @items.empty? %>
    <div class="empty-state py-12">
      <svg class="empty-state-icon w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      <p class="empty-state-title">No items in active lists</p>
      <p class="empty-state-subtitle">Create items or mark lists as active to see them here</p>
      <%= link_to "Create a list", new_list_path, class: "btn btn-primary inline-flex items-center mt-4" %>
    </div>
  <% end %>
</div>

<!-- Subscribe to real-time updates -->
<%= turbo_stream_from "user_list_items_#{current_user.id}" %>
