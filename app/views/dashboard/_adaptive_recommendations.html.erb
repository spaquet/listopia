<!-- app/views/dashboard/_adaptive_recommendations.html.erb -->
<div class="space-y-3">
  <% if recommendations.any? %>
    <% recommendations.each_with_index do |rec, index| %>
      <div class="recommendation-card">
        <!-- Card Header: Title + Actions -->
        <div class="recommendation-card-header">
          <div class="flex-1 min-w-0">
            <h4 class="recommendation-card-title">
              <%= link_to rec[:list_title], list_path(rec[:list_id]) %>
            </h4>
            <% if !rec[:is_owned] %>
              <p class="recommendation-card-owner">by <%= rec[:list_owner] %></p>
            <% end %>
          </div>
          <div class="flex items-start gap-1 flex-shrink-0">
            <!-- Urgency Indicator -->
            <% if rec[:score] > 100 %>
              <span class="urgency-dot high" title="High priority"></span>
            <% elsif rec[:score] > 50 %>
              <span class="urgency-dot medium" title="Medium priority"></span>
            <% end %>
            <!-- Spotlight Arrow -->
            <%= link_to dashboard_focus_list_path(list_id: rec[:list_id], mode: :spotlight, format: :turbo_stream),
                        data: { turbo_stream: true },
                        class: "card-action-button" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            <% end %>
          </div>
        </div>

        <!-- Reason Tags -->
        <div class="recommendation-card-meta">
          <% rec[:reason].split(" • ").each do |reason_part| %>
            <span class="recommendation-card-reason"><%= reason_part %></span>
          <% end %>
        </div>

        <!-- Progress Bar with Label -->
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-2xs text-ink-subtle uppercase tracking-wider">Progress</span>
            <span class="text-xs font-semibold text-ink"><%= rec[:completion_rate] %>%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-bar-fill" style="width: <%= rec[:completion_rate] %>%"></div>
          </div>
        </div>

        <!-- Stats Line -->
        <div class="recommendation-card-stats">
          <div class="flex gap-3">
            <span>
              <span class="recommendation-card-stat-value"><%= rec[:pending_count] %></span>
              pending
            </span>
            <% if rec[:collaborator_count] > 0 %>
              <span>
                <span class="recommendation-card-stat-value"><%= rec[:collaborator_count] %></span>
                collab.
              </span>
            <% end %>
          </div>
        </div>

        <!-- Next Item Preview -->
        <% if rec[:next_item] %>
          <div class="recommendation-next-item">
            <p class="recommendation-next-item-label">Next item</p>
            <div class="recommendation-next-item-content">
              <div class="recommendation-next-item-checkbox"></div>
              <div class="flex-1 min-w-0">
                <p class="recommendation-next-item-title">
                  <%= rec[:next_item][:title] %>
                </p>
                <% if rec[:next_item][:due_date] %>
                  <p class="recommendation-next-item-due">
                    Due <%= time_ago_in_words_or_date(rec[:next_item][:due_date]) %>
                  </p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="empty-state">
      <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <p class="empty-state-title">All caught up!</p>
      <p class="empty-state-subtitle">No urgent items right now.</p>
    </div>
  <% end %>
</div>
