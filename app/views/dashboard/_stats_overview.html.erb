<!-- app/views/dashboard/_stats_overview.html.erb -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
  <div class="card p-4">
    <div class="flex items-center">
      <div class="shrink-0">
        <div class="w-8 h-8 bg-surface-raised rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
        </div>
      </div>
      <div class="ml-3 flex-1">
        <p class="t-meta text-ink-muted">My Lists</p>
        <div class="flex items-baseline gap-2">
          <p class="text-lg font-semibold text-ink"><%= stats[:owned_lists] %></p>
          <% if stats[:collaborated_lists].to_i > 0 %>
            <p class="text-xs text-ink-muted">+ <%= stats[:collaborated_lists] %> shared</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <div class="card p-4">
    <div class="flex items-center">
      <div class="shrink-0">
        <div class="w-8 h-8 bg-surface-raised rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
      <div class="ml-3">
        <p class="t-meta text-ink-muted">Completed</p>
        <p class="text-lg font-semibold text-ink"><%= stats[:completed_items] %>/<%= stats[:total_items] %></p>
      </div>
    </div>
  </div>
  <div class="card p-4">
    <div class="flex items-center">
      <div class="shrink-0">
        <div class="w-8 h-8 bg-surface-raised rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
      <div class="ml-3">
        <p class="t-meta text-ink-muted">Active Lists</p>
        <p class="text-lg font-semibold text-ink"><%= stats[:active_lists] %></p>
      </div>
    </div>
  </div>
  <div class="card p-4">
    <div class="flex items-center">
      <div class="shrink-0">
        <div class="w-8 h-8 bg-surface-raised rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
        </div>
      </div>
      <div class="ml-3">
        <p class="t-meta text-ink-muted">Overdue</p>
        <p class="text-lg font-semibold text-ink"><%= stats[:overdue_items] %></p>
      </div>
    </div>
  </div>
</div>