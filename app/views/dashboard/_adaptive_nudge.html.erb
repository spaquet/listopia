<!-- app/views/dashboard/_adaptive_nudge.html.erb -->
<div class="space-y-4">
  <!-- Main Nudge Message -->
  <div class="nudge-alert">
    <div class="nudge-alert-icon">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
    </div>
    <div class="nudge-alert-content">
      <h4>Let's get back on track!</h4>
      <p>You've been away for a bit. Here are the lists that could use your attention.</p>
    </div>
  </div>

  <!-- Recommendations with Nudge Context -->
  <div class="space-y-3">
    <% if recommendations.any? %>
      <% recommendations.first(3).each do |rec| %>
        <div class="recommendation-card">
          <!-- Card Header: Title + Arrow -->
          <div class="recommendation-card-header">
            <div class="flex-1 min-w-0">
              <h4 class="recommendation-card-title">
                <%= link_to rec[:list_title], list_path(rec[:list_id]) %>
              </h4>
              <p class="recommendation-card-owner"><%= rec[:reason] %></p>
            </div>
            <!-- Spotlight Arrow -->
            <%= link_to dashboard_focus_list_path(list_id: rec[:list_id], mode: :spotlight, format: :turbo_stream),
                        data: { turbo_stream: true },
                        class: "card-action-button" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            <% end %>
          </div>

          <!-- Progress Bar -->
          <div class="progress-bar mb-2">
            <div class="progress-bar-fill warning" style="width: <%= rec[:completion_rate] %>%"></div>
          </div>

          <!-- Stats -->
          <div class="recommendation-card-stats">
            <span>
              <span class="recommendation-card-stat-value"><%= rec[:pending_count] %></span>
              pending items
            </span>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="empty-state-title">Great news!</p>
        <p class="empty-state-subtitle">All your lists are up to date.</p>
      </div>
    <% end %>
  </div>

  <!-- Motivation -->
  <div class="nudge-motivation">
    💪 You've got this! Starting with just one item can build momentum.
  </div>
</div>