<!-- app/views/dashboard/kanban.html.erb -->
<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="t-display-s text-ink">Board View</h1>
    <p class="mt-2 text-ink-muted">See all your lists organized by status</p>
  </div>

  <!-- View Toggle -->
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-2">
      <%= link_to root_path,
                  class: "btn btn-secondary inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6z"></path>
        </svg>
        Dashboard View
      <% end %>
      <span class="pill accent inline-flex items-center">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
        </svg>
        Board View
      </span>
    </div>

    <%= link_to new_list_path,
                class: "btn btn-primary inline-flex items-center" do %>
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      New List
    <% end %>
  </div>

  <!-- Kanban Columns -->
  <div class="overflow-x-auto pb-6">
    <div class="flex gap-6 min-w-min">
      <% @lists_by_status.each do |status, lists| %>
        <div class="kanban-column">
          <!-- Column Header -->
          <div class="kanban-column-header">
            <div>
              <h3 class="kanban-column-title">
                <%= status.humanize %>
                <span class="kanban-column-count">
                  <%= lists.count %>
                </span>
              </h3>
            </div>
            <!-- Status Icon -->
            <span class="status-indicator <%= status.downcase %>" title="<%= status.humanize %>">
              <% case status %>
              <% when 'draft' %>
                ◯
              <% when 'active' %>
                ●
              <% when 'completed' %>
                ✓
              <% when 'archived' %>
                ⊘
              <% end %>
            </span>
          </div>

          <!-- Column Items -->
          <div class="kanban-column-items">
            <% if lists.any? %>
              <% lists.each do |list| %>
                <%= render "lists/kanban_list_card", list: list %>
              <% end %>
            <% else %>
              <div class="empty-state">
                <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                </svg>
                <p class="empty-state-subtitle">No lists</p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
