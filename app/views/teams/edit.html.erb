<div class="space-y-6 max-w-2xl">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="t-display-m text-ink">Edit Team</h1>
      <p class="mt-2 text-ink-muted">Update settings for <%= @team.name %></p>
    </div>
    <%= link_to "← Back", organization_team_path(@organization, @team), class: "btn btn-secondary" %>
  </div>

  <div class="card">
    <%= render "form", organization: @organization, team: @team %>
  </div>
</div>
