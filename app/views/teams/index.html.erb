<!-- app/views/teams/index.html.erb -->
<div class="max-w-6xl mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Sidebar -->
    <div class="lg:col-span-1">
      <div class="card sticky top-4">
        <%= render "shared/settings_sidebar" %>
      </div>
    </div>
    <!-- Main Content -->
    <div class="lg:col-span-3 space-y-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="t-display-m text-ink">Teams</h1>
          <p class="mt-2 text-ink-muted">Organize your team members in <%= @organization.name %></p>
        </div>
        <div class="flex gap-2">
          <% if policy(@organization).manage_teams? %>
            <%= link_to "New Team", new_organization_team_path(@organization), class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>
      <% if @teams.any? %>
        <div class="grid gap-4">
          <% @teams.each do |team| %>
            <div class="card hover:shadow-pop transition-shadow duration-fast">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h2 class="t-body-l font-semibold text-ink">
                    <%= link_to team.name, organization_team_path(@organization, team), class: "hover:text-accent transition-colors duration-fast" %>
                  </h2>
                  <p class="t-meta text-ink-muted mt-1">
                    <%= team.users.count %> members · Created <%= time_ago_in_words(team.created_at) %> ago
                  </p>
                </div>
                <div class="flex gap-2">
                  <% if policy(team).update? %>
                    <%= link_to "Edit", edit_organization_team_path(@organization, team), class: "btn btn-secondary btn-sm" %>
                  <% end %>
                  <% if policy(team).manage_members? %>
                    <%= link_to "View", organization_team_path(@organization, team), class: "btn btn-primary btn-sm" %>
                  <% end %>
                  <% if policy(team).destroy? %>
                    <%= link_to "Delete", organization_team_path(@organization, team), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="card text-center py-12">
          <p class="text-ink-muted mb-4">No teams created yet.</p>
          <% if policy(@organization).manage_teams? %>
            <%= link_to "Create your first team", new_organization_team_path(@organization), class: "btn btn-primary" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
