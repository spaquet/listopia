<%= form_with model: [@organization, @team], local: true, class: "space-y-6" do |f| %>
  <% if @team.errors.any? %>
    <div class="alert alert-danger">
      <h3 class="font-semibold mb-2">
        <%= pluralize(@team.errors.count, "error") %> prevented this team from being saved:
      </h3>
      <ul class="list-disc list-inside text-sm">
        <% @team.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "Team Name", class: "form-label" %>
    <%= f.text_field :name,
      class: "form-input",
      placeholder: "Engineering Team",
      required: true
    %>
    <p class="mt-1 t-meta text-ink-muted">The name of your team</p>
  </div>

  <div class="flex gap-2 pt-4 border-t border-rule">
    <%= f.submit @team.persisted? ? "Update Team" : "Create Team",
      class: "btn btn-primary"
    %>
    <%= link_to "Cancel",
      @team.persisted? ? organization_team_path(@organization, @team) : organization_teams_path(@organization),
      class: "btn btn-secondary"
    %>
  </div>
<% end %>
