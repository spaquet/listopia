<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="t-display-m text-ink"><%= @team.name %></h1>
      <p class="mt-2 text-ink-muted">Team in <%= @organization.name %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "← Back", organization_teams_path(@organization), class: "btn btn-secondary" %>
      <% if policy(@team).update? %>
        <%= link_to "Edit", edit_organization_team_path(@organization, @team), class: "btn btn-secondary" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="card">
      <div class="t-eyebrow text-ink-muted">Members</div>
      <div class="text-3xl font-bold text-ink mt-2"><%= @team.users.count %></div>
    </div>
    <div class="card">
      <div class="t-eyebrow text-ink-muted">Lists</div>
      <div class="text-3xl font-bold text-ink mt-2"><%= @team.lists.count %></div>
    </div>
    <div class="card">
      <div class="t-eyebrow text-ink-muted">Created</div>
      <div class="text-lg font-bold text-ink mt-2"><%= @team.created_at.strftime("%b %d, %Y") %></div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h2 class="t-body-l font-semibold text-ink">Team Details</h2>
    </div>
    <div class="card-body">
      <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <dt class="t-eyebrow text-ink-muted">Team Name</dt>
          <dd class="mt-1 text-ink"><%= @team.name %></dd>
        </div>
        <div>
          <dt class="t-eyebrow text-ink-muted">Slug</dt>
          <dd class="mt-1 text-ink"><%= @team.slug %></dd>
        </div>
        <div>
          <dt class="t-eyebrow text-ink-muted">Created By</dt>
          <dd class="mt-1 text-ink"><%= @team.creator.name %></dd>
        </div>
        <div>
          <dt class="t-eyebrow text-ink-muted">Organization</dt>
          <dd class="mt-1 text-ink"><%= @organization.name %></dd>
        </div>
      </dl>
    </div>
  </div>

  <% if policy(@team).manage_members? %>
    <div class="card overflow-hidden">
      <div class="card-header flex items-center justify-between border-b border-rule">
        <h2 class="t-body-l font-semibold text-ink">Team Members</h2>
        <%= link_to "Add Member", new_organization_team_member_path(@organization, @team), class: "btn btn-primary btn-sm" %>
      </div>

      <% pending_invitations = Invitation.where(invitable_type: 'Team', invitable_id: @team.id, status: 'pending') %>
      <% if @team.users.any? || pending_invitations.any? %>
        <div class="hidden md:grid md:grid-cols-5 gap-4 px-6 py-3 bg-surface-raised border-b border-rule font-semibold t-eyebrow text-ink">
          <div>Name</div>
          <div>Email</div>
          <div>Role</div>
          <div>Status</div>
          <div class="text-right">Actions</div>
        </div>
        <%= turbo_frame_tag "team_members" do %>
          <div class="divide-y divide-rule">
            <!-- Active Members -->
            <% @team.team_memberships.order(created_at: :desc).each do |membership| %>
              <div id="team_member_<%= membership.id %>" class="px-6 py-4 hover:bg-surface-raised grid grid-cols-1 md:grid-cols-5 gap-4 md:gap-4 md:items-center transition-colors duration-fast">
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                  <span class="t-meta text-ink-muted md:hidden">Name</span>
                  <span class="t-body-s font-medium text-ink"><%= membership.user.name %></span>
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                  <span class="t-meta text-ink-muted md:hidden">Email</span>
                  <span class="t-body-s text-ink-muted"><%= membership.user.email %></span>
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                  <span class="t-meta text-ink-muted md:hidden">Role</span>
                  <span class="pill <%= membership.role == 'admin' ? 'accent' : membership.role == 'lead' ? 'success' : 'default' %>">
                    <%= membership.role.titleize %>
                  </span>
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                  <span class="t-meta text-ink-muted md:hidden">Status</span>
                  <span class="pill success">
                    Active
                  </span>
                </div>
                <% if policy(@team).manage_members? && membership.user != current_user %>
                  <div class="flex items-center justify-start md:justify-end gap-3 pt-2 md:pt-0 border-t md:border-t-0 border-rule md:border-rule">
                    <div class="relative group">
                      <button type="button" class="t-body-s text-accent hover:text-accent bg-none border-0 cursor-pointer p-0 font-semibold">
                        Edit Role ▼
                      </button>
                      <div class="absolute bottom-full right-0 mb-1 w-40 bg-surface-raised border border-rule rounded-md shadow-pop hidden group-hover:block z-10">
                        <% %w[member lead admin].each do |role| %>
                          <div class="px-4 py-2 t-body-s text-ink hover:bg-surface transition-colors duration-fast flex items-center justify-between">
                            <% if membership.role != role %>
                              <%= button_to role.titleize, update_role_organization_team_member_path(@organization, @team, membership, role: role), method: :patch, form: { local: false, class: "w-full text-left" }, class: "w-full text-left bg-none border-0 cursor-pointer font-normal p-0" %>
                            <% else %>
                              <span><%= role.titleize %></span>
                              <span class="font-bold">✓</span>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    <%= button_to "Remove", remove_organization_team_member_path(@organization, @team, membership), method: :delete, form: { local: false, class: "inline" }, class: "t-body-s text-danger hover:text-danger bg-none border-0 cursor-pointer p-0 font-semibold", data: { turbo_confirm: "Are you sure?" } %>
                  </div>
                <% elsif membership.user == current_user %>
                  <div class="flex items-center justify-start md:justify-end pt-2 md:pt-0 border-t md:border-t-0 border-rule md:border-rule">
                    <span class="t-meta text-ink-muted">You</span>
                  </div>
                <% end %>
              </div>
            <% end %>

            <!-- Pending Invitations -->
            <% pending_invitations.each do |invitation| %>
              <div id="team_invitation_<%= invitation.id %>" class="px-6 py-4 hover:bg-surface-raised grid grid-cols-1 md:grid-cols-5 gap-4 md:gap-4 md:items-center opacity-75 transition-colors duration-fast">
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                  <span class="t-meta text-ink-muted md:hidden">Name</span>
                  <span class="t-body-s font-medium text-ink">-</span>
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                  <span class="t-meta text-ink-muted md:hidden">Email</span>
                  <span class="t-body-s text-ink-muted"><%= invitation.email %></span>
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                  <span class="t-meta text-ink-muted md:hidden">Role</span>
                  <span class="pill">
                    <%= invitation.metadata['role']&.titleize || 'Member' %>
                  </span>
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-2">
                  <span class="t-meta text-ink-muted md:hidden">Status</span>
                  <span class="pill warning">
                    Invited
                  </span>
                </div>
                <div class="flex items-center justify-start md:justify-end gap-3 pt-2 md:pt-0 border-t md:border-t-0 border-rule md:border-rule">
                  <%= button_to "Resend", resend_invitation_organization_team_member_path(@organization, @team, invitation), method: :post, form: { local: false, class: "inline" }, class: "t-body-s text-accent hover:text-accent bg-none border-0 cursor-pointer p-0 font-semibold" %>
                  <%= button_to "Cancel", cancel_invitation_organization_team_member_path(@organization, @team, invitation), method: :delete, form: { local: false, class: "inline", data: { turbo_confirm: "Are you sure?" } }, class: "t-body-s text-danger hover:text-danger bg-none border-0 cursor-pointer p-0 font-semibold" %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="card-body text-center py-12">
          <p class="text-ink-muted mb-4">No members in this team yet.</p>
          <%= link_to "Add the first member", new_organization_team_member_path(@organization, @team), class: "text-accent hover:text-accent font-medium" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="flex gap-2">
    <% if policy(@team).destroy? %>
      <%= link_to "Delete Team", organization_team_path(@organization, @team), method: :delete, data: { confirm: "Are you sure? This action cannot be undone." }, class: "btn btn-danger" %>
    <% end %>
  </div>
</div>
