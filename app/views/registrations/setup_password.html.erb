<!-- app/views/registrations/setup_password.html.erb -->
<div class="min-h-screen flex items-center justify-center bg-surface py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div>
      <h2 class="text-3xl font-bold text-ink">Set Your Password</h2>
      <p class="mt-2 text-sm text-ink-muted">
        Welcome to Listopia! An administrator has created your account.
        Please set a password to get started.
      </p>
    </div>
    <%= form_with model: @user,
                   url: complete_setup_password_registration_path(token: token),
                   method: :post,
                   local: true,
                   data: { turbo: false },
                   class: "mt-8 space-y-6 card" do |f| %>
      <div class="card-body space-y-6">
        <!-- CSRF Token is automatically included by form_with -->
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <div class="alert-icon">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="alert-content">
              <p class="alert-message">
                <%= @user.errors.full_messages.first %>
              </p>
            </div>
          </div>
        <% end %>
        <div>
          <%= f.label :password, "Password", class: "form-label" %>
          <%= f.password_field :password,
                               required: true,
                               minlength: 8,
                               class: "form-input",
                               placeholder: "At least 8 characters" %>
          <p class="mt-1 text-xs text-ink-muted">Minimum 8 characters</p>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
          <%= f.password_field :password_confirmation,
                               required: true,
                               class: "form-input",
                               placeholder: "Confirm your password" %>
        </div>
        <div>
          <%= f.submit "Set Password & Sign In", class: "w-full btn btn-primary" %>
        </div>
      </div>
    <% end %>
    <p class="text-center text-sm text-ink-muted">
      <%= link_to "Back to Sign In", new_session_path, class: "font-medium text-accent hover:text-accent" %>
    </p>
  </div>
</div>