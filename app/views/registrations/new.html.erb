<!-- app/views/registrations/new.html.erb -->
<div class="min-h-screen flex items-center justify-center bg-surface py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div>
      <div class="mx-auto h-12 w-12 bg-accent rounded-lg flex items-center justify-center">
        <span class="text-ink-inverse font-bold text-xl">L</span>
      </div>
      <h2 class="mt-6 text-center text-3xl font-bold text-ink">
        Create your account
      </h2>
      <p class="mt-2 text-center text-sm text-ink-muted">
        Start organizing your life with Listopia
      </p>
    </div>
    <div class="card">
      <div class="card-body space-y-6">
        <%= form_with model: @user,
                      url: registration_path,
                      data: { turbo: false },
                      class: "space-y-6" do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <div class="alert-icon">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="alert-content">
                <h3 class="alert-title">Please fix the following errors:</h3>
                <ul class="mt-2 text-sm space-y-1 list-disc list-inside">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          <% end %>
          <div>
            <%= f.label :name, "Full name", class: "form-label" %>
            <%= f.text_field :name,
                             required: true,
                             autofocus: true,
                             autocomplete: "name",
                             class: "form-input" %>
          </div>
          <div>
            <%= f.label :email, "Email address", class: "form-label" %>
            <%= f.email_field :email,
                              required: true,
                              autocomplete: "email",
                              class: "form-input" %>
          </div>
          <div>
            <%= f.label :password, "Password", class: "form-label" %>
            <%= f.password_field :password,
                                 required: true,
                                 autocomplete: "new-password",
                                 minlength: 8,
                                 class: "form-input" %>
            <p class="mt-1 text-xs text-ink-muted">Must be at least 8 characters long</p>
          </div>
          <div>
            <%= f.label :password_confirmation, "Confirm password", class: "form-label" %>
            <%= f.password_field :password_confirmation,
                                 required: true,
                                 autocomplete: "new-password",
                                 class: "form-input" %>
          </div>
          <div>
            <%= f.submit "Create Account", class: "w-full btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
    <div class="text-center">
      <p class="text-sm text-ink-muted">
        Already have an account?
        <%= link_to "Sign in here", new_session_path,
                    class: "font-medium text-accent hover:text-accent transition-colors duration-200" %>
      </p>
    </div>
  </div>
</div>