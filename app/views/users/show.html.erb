<!-- app/views/users/show.html.erb -->
<div class="max-w-4xl mx-auto space-y-6">
  <!-- Page Header with User Avatar -->
  <div class="card">
    <div class="flex items-start justify-between">
      <div class="flex items-center space-x-4">
        <%= user_avatar_initials(current_user, size: 'w-16 h-16 text-xl') %>
        <div>
          <h1 class="t-display-s text-ink"><%= current_user.name %></h1>
          <p class="text-ink-muted"><%= current_user.email %></p>
          <% if current_user.bio.present? %>
            <p class="t-body-s text-ink-muted mt-2"><%= current_user.bio %></p>
          <% end %>
          <p class="t-meta text-ink-muted mt-3">Member since <%= current_user.created_at.strftime("%B %Y") %> • UID: <span class="font-mono"><%= current_user.id %></span></p>
        </div>
      </div>
      <div class="flex space-x-3">
        <%= link_to edit_user_path, class: "btn btn-primary flex items-center" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          Edit Profile
        <% end %>
        <%= link_to settings_user_path, class: "btn btn-secondary flex items-center" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          Settings
        <% end %>
      </div>
    </div>
  </div>
  <!-- Profile Information Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Account Info -->
    <div class="card">
      <h2 class="t-body-l font-semibold text-ink mb-4">Account Information</h2>
      <dl class="space-y-4">
        <div>
          <dt class="t-eyebrow text-ink-muted">Email</dt>
          <dd class="mt-1 t-body-s text-ink"><%= current_user.email %></dd>
        </div>
        <div>
          <dt class="t-eyebrow text-ink-muted">Account Status</dt>
          <dd class="mt-1">
            <% if current_user.active? %>
              <span class="pill success">Active</span>
            <% elsif current_user.suspended? %>
              <span class="pill danger">Suspended</span>
            <% else %>
              <span class="pill">Inactive</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="t-eyebrow text-ink-muted">Timezone</dt>
          <dd class="mt-1 t-body-s text-ink"><%= current_user.timezone || "Not set" %></dd>
        </div>
        <div>
          <dt class="t-eyebrow text-ink-muted">Language</dt>
          <dd class="mt-1 t-body-s text-ink"><%= current_user.locale&.humanize || "English" %></dd>
        </div>
      </dl>
    </div>
    <!-- Activity Stats -->
    <div class="card">
      <h2 class="t-body-l font-semibold text-ink mb-4">Activity</h2>
      <dl class="space-y-4">
        <div>
          <dt class="t-eyebrow text-ink-muted">Lists Created</dt>
          <dd class="mt-1 text-3xl font-bold text-accent"><%= current_user.lists.count %></dd>
        </div>
        <div>
          <dt class="t-eyebrow text-ink-muted">Shared Lists</dt>
          <dd class="mt-1 text-3xl font-bold text-accent"><%= current_user.collaborated_lists.count %></dd>
        </div>
        <div>
          <dt class="t-eyebrow text-ink-muted">Last Sign In</dt>
          <dd class="mt-1 t-body-s text-ink">
            <% if current_user.last_sign_in_at %>
              <%= current_user.last_sign_in_at.strftime("%B %d, %Y at %I:%M %p") %>
            <% else %>
              Never
            <% end %>
          </dd>
        </div>
      </dl>
    </div>
  </div>
  <!-- Account Security Section -->
  <div class="card">
    <h2 class="t-body-l font-semibold text-ink mb-4">Security</h2>
    <div class="space-y-4">
      <div class="flex items-center justify-between pb-4 border-b border-rule">
        <div>
          <p class="t-body-s font-semibold text-ink">Password</p>
          <p class="t-meta text-ink-muted mt-1">Manage your password</p>
        </div>
        <%= link_to "Change Password", settings_user_path, class: "text-accent hover:text-accent t-body-s font-semibold" %>
      </div>
      <div class="flex items-center justify-between">
        <div>
          <p class="t-body-s font-semibold text-ink">Email Verification</p>
          <% if current_user.email_verified_at %>
            <p class="t-meta text-success mt-1">✓ Email verified</p>
          <% else %>
            <p class="t-meta text-warning mt-1">⚠ Email not verified</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>