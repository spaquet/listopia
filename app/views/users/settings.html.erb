<!-- app/views/users/settings.html.erb -->
<div class="max-w-6xl mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Sidebar -->
    <div class="lg:col-span-1">
      <div class="card sticky top-4">
        <%= render "shared/settings_sidebar" %>
      </div>
    </div>

    <!-- Main Content -->
    <div class="lg:col-span-3 space-y-6">
      <!-- Page Header -->
      <div class="card">
        <h1 class="t-display-s text-ink">Account Settings</h1>
        <p class="text-ink-muted mt-1">Manage your password, account preferences, and notification settings.</p>
      </div>

      <!-- Application Version -->
      <div class="card">
        <h2 class="t-body-l font-semibold text-ink mb-1">Application Version</h2>
        <p class="t-meta text-ink-muted mb-4">Current version of Listopia running on this server.</p>
        <div class="flex items-center gap-4">
          <span class="pill accent">
            v<%= APP_VERSION %>
          </span>
          <span class="t-meta text-ink-muted font-mono">Build: <%= APP_BUILD %></span>
        </div>
      </div>

  <!-- Change Password -->
  <div class="card">
    <h2 class="t-body-l font-semibold text-ink mb-4">Change Password</h2>
    <%= form_with url: update_password_user_path, method: :patch, local: true, class: "space-y-4" do |f| %>
      <% if flash[:alert] %>
        <div class="alert alert-danger">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <div class="form-group">
        <%= f.label :current_password, "Current Password", class: "form-label" %>
        <%= f.password_field :current_password,
                             required: true,
                             class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label "user[password]", "New Password", class: "form-label" %>
        <%= f.password_field "user[password]",
                             minlength: 8,
                             class: "form-input" %>
        <p class="mt-1 t-meta text-ink-muted">Must be at least 8 characters long.</p>
      </div>
      <div class="form-group">
        <%= f.label "user[password_confirmation]", "Confirm New Password", class: "form-label" %>
        <%= f.password_field "user[password_confirmation]",
                             class: "form-input" %>
      </div>
      <div class="pt-4 border-t border-rule">
        <%= f.submit "Update Password",
                     class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
  <!-- Notification Settings -->
  <div class="card">
    <div class="mb-6">
      <h2 class="t-body-l font-semibold text-ink">Notification Preferences</h2>
      <p class="t-meta text-ink-muted mt-1">Configure how and when you receive notifications</p>
    </div>
    <%= form_with url: update_notification_settings_user_path, method: :patch, local: true, class: "space-y-6" do |f| %>
      <% if flash[:alert] %>
        <div class="alert alert-danger">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <!-- Delivery Channels -->
      <div>
        <h3 class="t-body-m font-semibold text-ink mb-4">Delivery Channels</h3>
        <div class="space-y-4">
          <!-- Email Notifications -->
          <div class="flex items-center justify-between">
            <div>
              <label class="t-body-s font-medium text-ink">Email Notifications</label>
              <p class="t-meta text-ink-muted">Receive notifications via email</p>
            </div>
            <%= f.fields_for :notification_settings, current_user.notification_preferences do |ns| %>
              <label class="relative inline-flex items-center cursor-pointer">
                <%= ns.check_box :email_notifications, 
                                 checked: current_user.notification_preferences.email_notifications?,
                                 class: "sr-only peer",
                                 data: { 
                                   action: "change->toggle#updateField",
                                   toggle_target: "input"
                                 } %>
                <div class="w-11 h-6 bg-surface-raised peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-rule after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent"></div>
              </label>
            <% end %>
          </div>
          <!-- SMS Notifications -->
          <div class="flex items-center justify-between">
            <div>
              <label class="t-body-s font-medium text-ink">SMS Notifications</label>
              <p class="t-meta text-ink-muted">Receive notifications via text message</p>
            </div>
            <%= f.fields_for :notification_settings, current_user.notification_preferences do |ns| %>
              <label class="relative inline-flex items-center cursor-pointer">
                <%= ns.check_box :sms_notifications,
                                 checked: current_user.notification_preferences.sms_notifications?,
                                 class: "sr-only peer",
                                 data: {
                                   action: "change->toggle#updateField",
                                   toggle_target: "input"
                                 } %>
                <div class="w-11 h-6 bg-surface-raised peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-rule after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent"></div>
              </label>
            <% end %>
          </div>
          <!-- Push Notifications -->
          <div class="flex items-center justify-between">
            <div>
              <label class="t-body-s font-medium text-ink">Push Notifications</label>
              <p class="t-meta text-ink-muted">Receive browser push notifications</p>
            </div>
            <%= f.fields_for :notification_settings, current_user.notification_preferences do |ns| %>
              <label class="relative inline-flex items-center cursor-pointer">
                <%= ns.check_box :push_notifications,
                                 checked: current_user.notification_preferences.push_notifications?,
                                 class: "sr-only peer",
                                 data: {
                                   action: "change->toggle#updateField",
                                   toggle_target: "input"
                                 } %>
                <div class="w-11 h-6 bg-surface-raised peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-rule after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent"></div>
              </label>
            <% end %>
          </div>
        </div>
      </div>
      <!-- Notification Types -->
      <div class="border-t border-rule pt-6">
        <h3 class="t-body-m font-semibold text-ink mb-4">Notification Types</h3>
        <div class="space-y-4">
          <!-- Collaboration Notifications -->
          <div class="flex items-center justify-between">
            <div>
              <label class="t-body-s font-medium text-ink">Collaboration</label>
              <p class="t-meta text-ink-muted">Invitations, new collaborators, permission changes</p>
            </div>
            <%= f.fields_for :notification_settings, current_user.notification_preferences do |ns| %>
              <label class="relative inline-flex items-center cursor-pointer">
                <%= ns.check_box :collaboration_notifications, 
                                 checked: current_user.notification_preferences.collaboration_notifications?,
                                 class: "sr-only peer",
                                 data: { 
                                   action: "change->toggle#updateField",
                                   toggle_target: "input"
                                 } %>
                <div class="w-11 h-6 bg-surface-raised peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-rule after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent"></div>
              </label>
            <% end %>
          </div>
          <!-- List Activity Notifications -->
          <div class="flex items-center justify-between">
            <div>
              <label class="t-body-s font-medium text-ink">List Updates</label>
              <p class="t-meta text-ink-muted">List title, description, and status changes</p>
            </div>
            <%= f.fields_for :notification_settings, current_user.notification_preferences do |ns| %>
              <label class="relative inline-flex items-center cursor-pointer">
                <%= ns.check_box :list_activity_notifications, 
                                 checked: current_user.notification_preferences.list_activity_notifications?,
                                 class: "sr-only peer",
                                 data: { 
                                   action: "change->toggle#updateField",
                                   toggle_target: "input"
                                 } %>
                <div class="w-11 h-6 bg-surface-raised peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-rule after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent"></div>
              </label>
            <% end %>
          </div>
          <!-- Item Activity Notifications -->
          <div class="flex items-center justify-between">
            <div>
              <label class="t-body-s font-medium text-ink">Item Activity</label>
              <p class="t-meta text-ink-muted">Items added, updated, completed, or deleted</p>
            </div>
            <%= f.fields_for :notification_settings, current_user.notification_preferences do |ns| %>
              <label class="relative inline-flex items-center cursor-pointer">
                <%= ns.check_box :item_activity_notifications, 
                                 checked: current_user.notification_preferences.item_activity_notifications?,
                                 class: "sr-only peer",
                                 data: { 
                                   action: "change->toggle#updateField",
                                   toggle_target: "input"
                                 } %>
                <div class="w-11 h-6 bg-surface-raised peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-rule after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent"></div>
              </label>
            <% end %>
          </div>
          <!-- Status Change Notifications -->
          <div class="flex items-center justify-between">
            <div>
              <label class="t-body-s font-medium text-ink">Status Changes</label>
              <p class="t-meta text-ink-muted">When lists change status (draft, active, completed, archived)</p>
            </div>
            <%= f.fields_for :notification_settings, current_user.notification_preferences do |ns| %>
              <label class="relative inline-flex items-center cursor-pointer">
                <%= ns.check_box :status_change_notifications, 
                                 checked: current_user.notification_preferences.status_change_notifications?,
                                 class: "sr-only peer",
                                 data: { 
                                   action: "change->toggle#updateField",
                                   toggle_target: "input"
                                 } %>
                <div class="w-11 h-6 bg-surface-raised peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-accent rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-rule after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-accent"></div>
              </label>
            <% end %>
          </div>
        </div>
      </div>
      <!-- Notification Frequency -->
      <div class="border-t border-rule pt-6">
        <h3 class="t-body-m font-semibold text-ink mb-4">Notification Frequency</h3>
        <%= f.fields_for :notification_settings, current_user.notification_preferences do |ns| %>
          <div class="space-y-3">
            <label class="flex items-center">
              <%= ns.radio_button :notification_frequency, "immediate",
                                  checked: current_user.notification_preferences.notification_frequency == 'immediate',
                                  class: "h-4 w-4 text-accent focus:ring-accent border-rule" %>
              <span class="ml-3">
                <span class="t-body-s font-medium text-ink">Immediate</span>
                <span class="block t-meta text-ink-muted">Get notified right away (respects quiet hours)</span>
              </span>
            </label>
            <label class="flex items-center">
              <%= ns.radio_button :notification_frequency, "daily_digest",
                                  checked: current_user.notification_preferences.notification_frequency == 'daily_digest',
                                  class: "h-4 w-4 text-accent focus:ring-accent border-rule" %>
              <span class="ml-3">
                <span class="t-body-s font-medium text-ink">Daily Digest</span>
                <span class="block t-meta text-ink-muted">Receive a summary once per day</span>
              </span>
            </label>
            <label class="flex items-center">
              <%= ns.radio_button :notification_frequency, "weekly_digest",
                                  checked: current_user.notification_preferences.notification_frequency == 'weekly_digest',
                                  class: "h-4 w-4 text-accent focus:ring-accent border-rule" %>
              <span class="ml-3">
                <span class="t-body-s font-medium text-ink">Weekly Digest</span>
                <span class="block t-meta text-ink-muted">Receive a summary once per week</span>
              </span>
            </label>
            <label class="flex items-center">
              <%= ns.radio_button :notification_frequency, "disabled",
                                  checked: current_user.notification_preferences.notification_frequency == 'disabled',
                                  class: "h-4 w-4 text-accent focus:ring-accent border-rule" %>
              <span class="ml-3">
                <span class="t-body-s font-medium text-ink">Disabled</span>
                <span class="block t-meta text-ink-muted">Turn off all notifications</span>
              </span>
            </label>
          </div>
        <% end %>
      </div>
      <!-- Save Button -->
      <div class="pt-4 border-t border-rule">
        <%= f.submit "Save Notification Preferences",
                     class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
  <!-- Account Actions -->
  <div class="card">
    <h2 class="t-body-l font-semibold text-ink mb-4">Account Actions</h2>
    <div class="space-y-4">
      <div class="flex items-center justify-between p-4 bg-surface-raised rounded-md">
        <div>
          <h3 class="t-body-s font-semibold text-ink">Account Verification</h3>
          <p class="t-meta text-ink-muted">
            <% if current_user.email_verified? %>
              ✅ Your email is verified
            <% else %>
              ⚠️ Email not yet verified
            <% end %>
          </p>
        </div>
        <% unless current_user.email_verified? %>
          <%= link_to "Resend Verification", "#",
                      class: "text-accent hover:text-accent t-body-s font-semibold" %>
        <% end %>
      </div>
      <div class="alert alert-danger p-4">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="t-body-s font-semibold text-danger">Delete Account</h3>
            <p class="t-meta text-danger">Permanently delete your account and all data</p>
          </div>
          <%= link_to "Delete Account", "#",
                      class: "text-danger hover:text-danger t-body-s font-semibold",
                      data: { confirm: "Are you sure? This action cannot be undone." } %>
        </div>
      </div>
    </div>
  </div>
      <!-- Navigation -->
      <div class="text-center">
        <%= link_to "← Back to Profile", profile_path,
                    class: "text-accent hover:text-accent font-medium" %>
      </div>
    </div>
  </div>
</div>