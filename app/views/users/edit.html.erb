<!-- app/views/users/edit.html.erb -->
<div class="max-w-2xl mx-auto">
  <div class="card">
    <div class="mb-6">
      <h1 class="t-display-s text-ink">Edit Profile</h1>
      <p class="text-ink-muted mt-1">Update your personal information and preferences.</p>
    </div>
    <%= form_with model: @user, local: true, class: "space-y-6" do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h3 class="font-semibold mb-2">Please fix the following errors:</h3>
          <ul class="list-disc list-inside space-y-1 text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div class="form-group">
        <%= f.label :name, "Full Name", class: "form-label" %>
        <%= f.text_field :name, class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label :email, "Email Address", class: "form-label" %>
        <%= f.email_field :email, class: "form-input" %>
        <p class="mt-1 t-meta text-ink-muted">
          Changing your email will require verification of the new address.
        </p>
      </div>
      <div class="form-group">
        <%= f.label :bio, "Bio", class: "form-label" %>
        <%= f.text_area :bio,
                        rows: 3,
                        placeholder: "Tell us a bit about yourself...",
                        class: "form-input" %>
      </div>
      <div class="form-group">
        <%= f.label :avatar_url, "Avatar URL", class: "form-label" %>
        <%= f.url_field :avatar_url,
                        placeholder: "https://example.com/avatar.jpg",
                        class: "form-input" %>
        <p class="mt-1 t-meta text-ink-muted">
          Optional: Link to your profile picture.
        </p>
      </div>
      <!-- Preferred language and timezone -->
      <div class="form-group">
        <%= f.label :locale, "Language/Locale", class: "form-label" %>
        <%= f.select :locale,
               options_for_select(locale_options, @user.locale),
               { prompt: "Select your preferred language" },
               { class: "form-input" } %>
        <p class="mt-1 t-meta text-ink-muted">
          This affects the language used in the interface and AI responses.
        </p>
      </div>
      <div class="form-group">
        <%= f.label :timezone, "Timezone", class: "form-label" %>
        <%= f.select :timezone,
               options_for_select(timezone_options, @user.timezone),
               { prompt: "Select your timezone" },
               { class: "form-input" } %>
        <p class="mt-1 t-meta text-ink-muted">
          Used for displaying dates and times in your local timezone.
        </p>
      </div>
      <div class="flex items-center justify-between pt-6 border-t border-rule">
        <%= link_to user_path,
                    class: "text-ink-muted hover:text-ink font-medium" do %>
          Cancel
        <% end %>
        <div class="flex space-x-3">
          <%= link_to settings_user_path,
                      class: "text-accent hover:text-accent font-medium" do %>
            Password & Settings
          <% end %>
          <%= f.submit "Update Profile",
                       class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>