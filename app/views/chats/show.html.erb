<div class="container mx-auto row-pad py-8">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-4">
      <%= link_to "← Back to Chats", chats_path, class: "text-accent hover:text-accent transition-colors" %>
      <h1 class="t-display-m text-ink"><%= @chat.title.presence || "Untitled Conversation" %></h1>
    </div>
    <div class="flex items-center gap-2">
      <% if @chat.archived? %>
        <%= button_to "Restore", restore_chat_path(@chat), method: :patch, class: "btn btn-secondary text-sm" %>
      <% else %>
        <%= button_to "Archive", archive_chat_path(@chat), method: :patch, class: "btn btn-secondary text-sm" %>
      <% end %>
      <%= button_to "Delete", chat_path(@chat), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-secondary text-danger text-sm" %>
    </div>
  </div>

  <!-- Unified Chat Component -->
  <div class="mb-6">
    <%= render "chat/unified_chat",
               chat: @chat,
               message_history: @messages,
               context: @chat_context %>
  </div>

  <!-- Chat Metadata -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
    <div class="card">
      <div class="card-body">
        <div class="text-2xl font-bold text-accent"><%= @chat.message_count %></div>
        <div class="t-eyebrow text-ink-muted">Messages</div>
      </div>
    </div>
    <div class="card">
      <div class="card-body">
        <div class="text-2xl font-bold text-accent"><%= @chat.turn_count %></div>
        <div class="t-eyebrow text-ink-muted">Turns</div>
      </div>
    </div>
    <div class="card">
      <div class="card-body">
        <div class="text-2xl font-bold text-accent"><%= @chat.user_message_count %></div>
        <div class="t-eyebrow text-ink-muted">Your Messages</div>
      </div>
    </div>
    <div class="card">
      <div class="card-body">
        <div class="text-2xl font-bold text-accent"><%= time_ago_in_words(@chat.created_at) %></div>
        <div class="t-eyebrow text-ink-muted">Created</div>
      </div>
    </div>
  </div>
</div>
