<!-- app/views/message_templates/_clarifying_questions.html.erb
     Generic form for asking clarifying questions in any chat context
     Works for list refinement, product recommendations, planning, etc.
-->

<% questions = data[:questions] || [] %>
<% chat_id = data[:chat_id] %>
<% context_title = data[:context_title] || "Please answer the following questions" %>

<% if questions.any? %>
  <div class="text-xs bg-blue-50 rounded-lg p-4 border border-blue-200 mt-4">
    <div class="mb-4">
      <h3 class="text-xs font-semibold text-gray-900 flex items-center gap-2">
        <span class="text-lg">❓</span>
        <%= context_title %>
      </h3>
      <p class="text-xs text-gray-600 mt-2">
        ✓ <%= questions.length %> question<%= questions.length != 1 ? 's' : '' %> - Your answers will help me provide more targeted recommendations.
      </p>
    </div>

    <!-- Form for answering questions -->
    <form id="clarifying-questions-form-<%= chat_id %>"
          data-controller="clarifying-questions"
          data-chat-id="<%= chat_id %>"
          data-questions="<%= h(questions.to_json) %>"
          class="space-y-4"
          method="POST"
          action="/chats/<%= chat_id %>/create_message">

      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <!-- Questions with input fields -->
      <% questions.each_with_index do |question, idx| %>
        <div class="border-l-4 border-blue-300 pl-4 py-2">
          <label class="block text-xs font-semibold text-gray-900 mb-2">
            <span class="text-blue-600"><%= idx + 1 %>.</span>
            <%= question["question"] %>
          </label>

          <% if question["context"].present? %>
            <p class="text-xs text-gray-600 mb-2 italic">
              💡 <%= question["context"] %>
            </p>
          <% end %>

          <% case question.dig("input_type") %>
          <% when "select" %>
            <!-- Dropdown for multiple choice -->
            <select name="message[answers][<%= idx %>]"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                    required>
              <option value="">-- Select an option --</option>
              <% (question["options"] || []).each do |option| %>
                <option value="<%= option %>"><%= option %></option>
              <% end %>
            </select>

          <% when "textarea" %>
            <!-- Multi-line text area -->
            <textarea name="message[answers][<%= idx %>]"
                      class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                      placeholder="Enter your answer..."
                      rows="3"
                      required></textarea>

          <% else %>
            <!-- Default: single line text input -->
            <input type="text"
                   name="message[answers][<%= idx %>]"
                   class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                   placeholder="Enter your answer..."
                   required />
          <% end %>
        </div>
      <% end %>

      <!-- Submit Button -->
      <div class="flex gap-3 pt-4 border-t border-gray-200">
        <button type="submit"
                class="flex-1 px-4 py-2 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
                data-action="clarifying-questions#submit">
          Submit Answers
        </button>

        <button type="button"
                class="px-4 py-2 text-gray-600 font-medium border border-gray-300 rounded-md hover:bg-gray-50 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-300"
                data-action="clarifying-questions#skip">
          Skip for Now
        </button>
      </div>
    </form>
  </div>
<% end %>
