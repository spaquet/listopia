<!-- app/views/message_templates/_pre_creation_planning.html.erb
     Template for pre-creation planning questions with input fields
     Allows users to answer clarifying questions before list creation
-->

<% questions = data[:questions] || [] %>
<% chat_id = data[:chat_id] %>
<% list_title = data[:list_title] %>

<% Rails.logger.debug("PreCreationPlanning - questions: #{questions.inspect}") %>
<% Rails.logger.debug("PreCreationPlanning - questions count: #{questions.length}") %>
<% if questions.any? %>
  <% Rails.logger.debug("PreCreationPlanning - first question: #{questions[0].inspect}") %>
<% end %>

<div class="text-xs bg-blue-50 rounded-lg p-4 border border-blue-200" style="min-height: 100px;">
  <div class="mb-4">
    <h3 class="text-xs font-semibold text-gray-900 flex items-center gap-2">
      <span class="text-lg">❓</span>
      Before I create "<%= list_title %>", I have a few questions
    </h3>
    <p class="text-xs text-gray-600 mt-2">
      <% if questions.empty? %>
        🔴 No questions loaded (questions array is empty)
      <% else %>
        ✓ <%= questions.length %> question<%= questions.length != 1 ? 's' : '' %> - Please provide answers to help me structure this list better.
      <% end %>
    </p>
  </div>

  <!-- Form for answering questions -->
  <form id="pre-creation-planning-form-<%= chat_id %>"
        data-controller="pre-creation-planning"
        data-chat-id="<%= chat_id %>"
        data-questions="<%= h(questions.to_json) %>"
        class="space-y-4"
        method="POST"
        action="/chats/<%= chat_id %>/create_message">

    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

    <!-- Questions with input fields -->
    <% questions.each_with_index do |question, idx| %>
      <div class="border-l-4 border-blue-300 pl-4 py-2">
        <label class="block text-xs font-semibold text-gray-900 mb-2">
          <span class="text-blue-600"><%= idx + 1 %>.</span>
          <%= question["question"] %>
        </label>

        <% if question["context"].present? %>
          <p class="text-xs text-gray-600 mb-2 italic">
            💡 <%= question["context"] %>
          </p>
        <% end %>

        <textarea name="message[answers][<%= idx %>]"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  placeholder="Enter your answer..."
                  rows="2"
                  required></textarea>
      </div>
    <% end %>

    <!-- Submit Button -->
    <div class="flex gap-3 pt-4 border-t border-gray-200">
      <button type="submit"
              class="flex-1 px-4 py-2 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
              data-action="pre-creation-planning#submit">
        Submit Answers
      </button>

      <button type="button"
              class="px-4 py-2 text-gray-600 font-medium border border-gray-300 rounded-md hover:bg-gray-50 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-300"
              data-action="pre-creation-planning#cancel">
        Cancel
      </button>
    </div>
  </form>
</div>

<style>
  textarea:focus {
    outline: none;
  }
</style>
