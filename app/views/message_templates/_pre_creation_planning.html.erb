<!-- app/views/message_templates/_pre_creation_planning.html.erb
     Template for pre-creation planning questions with input fields
     Uses the same unified form styling as clarifying_questions
     Allows users to answer clarifying questions before list creation
-->

<% questions = data[:questions] || [] %>
<% chat_id = data[:chat_id] %>
<% list_title = data[:list_title] %>
<% context_title = list_title.present? ? "Before I create \"#{list_title}\", I have a few questions" : "I have a few questions" %>

<% if questions.any? %>
  <div class="bg-blue-50 rounded-lg p-5 border-2 border-blue-300 mt-6">
    <div class="mb-5">
      <h3 class="text-sm font-bold text-gray-900 flex items-center gap-2">
        <span class="text-2xl">❓</span>
        <%= context_title %>
      </h3>
      <p class="text-sm text-gray-700 mt-2 font-medium">
        ✓ <%= questions.length %> question<%= questions.length != 1 ? 's' : '' %> • Your answers will help me structure this list better.
      </p>
    </div>

    <!-- Form for answering questions -->
    <form id="pre-creation-planning-form-<%= chat_id %>"
          data-controller="pre-creation-planning"
          data-chat-id="<%= chat_id %>"
          data-questions="<%= h(questions.to_json) %>"
          class="space-y-5"
          method="POST"
          action="/chats/<%= chat_id %>/create_message">

      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <!-- Questions with input fields -->
      <% questions.each_with_index do |question, idx| %>
        <div class="bg-white rounded-lg p-4 border border-blue-200 hover:border-blue-400 transition-colors">
          <label class="block text-sm font-semibold text-gray-900 mb-3">
            <span class="inline-block bg-blue-600 text-white rounded-full w-6 h-6 text-center text-xs leading-6 font-bold"><%= idx + 1 %></span>
            <span class="ml-2"><%= question["question"] %></span>
          </label>

          <% if question["context"].present? %>
            <p class="text-sm text-gray-600 mb-3 italic bg-blue-100 px-3 py-2 rounded border-l-3 border-blue-400">
              💡 <%= question["context"] %>
            </p>
          <% end %>

          <!-- Textarea for longer answers -->
          <textarea name="message[answers][<%= idx %>]"
                    class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 hover:border-gray-400 transition-colors"
                    placeholder="Enter your answer..."
                    rows="3"
                    required></textarea>
        </div>
      <% end %>

      <!-- Submit Button -->
      <div class="flex gap-3 pt-5 border-t-2 border-blue-200 mt-5">
        <button type="submit"
                class="flex-1 px-5 py-3 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm"
                data-action="pre-creation-planning#submit">
          Submit Answers
        </button>

        <button type="button"
                class="px-5 py-3 text-gray-700 font-medium border-2 border-gray-300 rounded-lg hover:bg-gray-50 hover:border-gray-400 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2"
                data-action="pre-creation-planning#cancel">
          Cancel
        </button>
      </div>
    </form>
  </div>
<% end %>
