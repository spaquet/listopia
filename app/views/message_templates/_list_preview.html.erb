<!-- app/views/message_templates/_list_preview.html.erb
     Shows a preview of the list that will be created
     Displays structure: parent items, sublists, and item counts
-->

<% planning_context = data[:planning_context] %>
<% parent_items = planning_context&.parent_requirements&.dig('items') || [] %>
<% subdivisions = planning_context&.hierarchical_items&.dig('subdivisions') || {} %>
<% subdivision_type = planning_context&.hierarchical_items&.dig('subdivision_type') || 'none' %>

<% if planning_context.present? %>
  <div id="list-preview-<%= planning_context.id %>" class="flex justify-start mb-4">
    <div class="max-w-2xl w-full">
      <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-lg p-4 border border-green-200">
        <!-- Header -->
        <div class="flex items-start gap-3 mb-4">
          <span class="text-2xl">📋</span>
          <div class="flex-1">
            <h3 class="text-sm font-bold text-gray-900">
              <%= planning_context.request_content.truncate(50) %>
            </h3>
            <p class="text-xs text-gray-600 mt-1">
              Preview of your list structure
            </p>
          </div>
        </div>

        <!-- Parent Items Section -->
        <% if parent_items.present? %>
          <div class="mb-4 pb-4 border-b border-green-200">
            <h4 class="text-xs font-semibold text-gray-700 mb-2 flex items-center gap-2">
              <span class="text-lg">📌</span>
              Main List Items
            </h4>
            <div class="space-y-1">
              <% parent_items.each do |item| %>
                <div class="flex items-start gap-2 text-xs">
                  <span class="text-gray-400 mt-0.5">•</span>
                  <div>
                    <span class="text-gray-900 font-medium"><%= item[:title] || item['title'] %></span>
                    <% if item[:priority] || item['priority'] %>
                      <span class="ml-2 px-1.5 py-0.5 rounded text-xs font-medium
                        <% case (item[:priority] || item['priority']).to_s %>
                        <% when 'high' %>
                          bg-red-100 text-red-700
                        <% when 'medium' %>
                          bg-yellow-100 text-yellow-700
                        <% else %>
                          bg-green-100 text-green-700
                        <% end %>
                      ">
                        <%= (item[:priority] || item['priority']).to_s.titleize %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Subdivisions Section -->
        <% if subdivisions.present? && subdivisions.length > 0 %>
          <div class="mb-4">
            <h4 class="text-xs font-semibold text-gray-700 mb-2 flex items-center gap-2">
              <span class="text-lg">📁</span>
              Sublists by <%= subdivision_type.titleize %>
              <span class="ml-auto px-2 py-0.5 bg-green-200 text-green-800 rounded text-xs font-semibold">
                <%= subdivisions.length %>
              </span>
            </h4>

            <div class="space-y-2">
              <% subdivisions.each do |sublist_name, sublist_data| %>
                <div class="bg-white rounded border border-green-100 p-3">
                  <!-- Sublist Header -->
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-semibold text-gray-900">
                      🏷️ <%= sublist_name %>
                    </span>
                    <% items_count = (sublist_data[:items] || []).length %>
                    <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-xs font-medium">
                      <%= items_count %> <%= items_count == 1 ? 'item' : 'items' %>
                    </span>
                  </div>

                  <!-- Sublist Items Preview (first 3) -->
                  <div class="space-y-1">
                    <% (sublist_data[:items] || []).take(3).each do |item| %>
                      <div class="flex items-start gap-2 text-xs">
                        <span class="text-gray-300">├</span>
                        <span class="text-gray-700 truncate">
                          <%= item[:title] || item['title'] %>
                        </span>
                      </div>
                    <% end %>

                    <!-- Show more indicator -->
                    <% if (sublist_data[:items] || []).length > 3 %>
                      <div class="text-xs text-gray-500 italic pl-3">
                        + <%= (sublist_data[:items] || []).length - 3 %> more <%= (sublist_data[:items] || []).length - 3 == 1 ? 'item' : 'items' %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Summary Stats -->
          <div class="pt-3 border-t border-green-200">
            <% total_items = parent_items.length + subdivisions.values.sum { |s| (s[:items] || []).length } %>
            <div class="flex items-center justify-between text-xs text-gray-600">
              <span>
                <span class="font-semibold text-gray-900"><%= total_items %></span> total items
              </span>
              <span>
                <span class="font-semibold text-gray-900"><%= subdivisions.length %></span> sublists
              </span>
            </div>
          </div>
        <% elsif parent_items.present? %>
          <!-- Simple list summary -->
          <div class="pt-3 border-t border-green-200">
            <div class="text-xs text-gray-600">
              <span class="font-semibold text-gray-900"><%= parent_items.length %></span> items ready to create
            </div>
          </div>
        <% end %>

        <!-- Ready Status -->
        <% if planning_context.state == 'completed' %>
          <div class="mt-4 pt-4 border-t border-green-200 flex items-center justify-between">
            <span class="text-xs font-semibold text-green-700 flex items-center gap-2">
              <span class="text-lg">✅</span>
              Ready to create!
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
