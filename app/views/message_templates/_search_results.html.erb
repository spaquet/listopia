<!-- app/views/message_templates/_search_results.html.erb
     Search results template for displaying /search command output
-->

<% search_data = data %>
<div class="text-xs space-y-3">
  <!-- Results List -->
  <% if search_data[:results].present? && search_data[:results].length > 0 %>
    <!-- Results Header -->
    <div class="mb-3">
      <h4 class="t-eyebrow text-ink-subtle mb-2">
        <%= search_data[:total_count] || 0 %> result<%= search_data[:total_count] != 1 ? "s" : "" %>
        <% if search_data[:query].present? %>
          for "<%= search_data[:query] %>"
        <% end %>
      </h4>
    </div>

    <div class="space-y-2">
      <% search_data[:results].each do |result| %>
        <a href="<%= result[:url] %>"
           class="block hover:bg-surface-raised rounded-md p-2 transition-colors duration-fast border border-rule"
           target="_blank"
           rel="noopener noreferrer">

          <!-- Result Title -->
          <p class="font-semibold text-accent hover:text-accent transition-colors duration-fast">
            <%= result[:title] %>
            <% if result[:type].present? %>
              <span class="ml-2 px-2 py-0.5 bg-surface-sunken text-ink text-xs rounded-sm font-medium">
                <%= result[:type].titleize %>
              </span>
            <% end %>
          </p>

          <!-- Result Description -->
          <% if result[:description].present? %>
            <p class="text-xs text-ink-muted mt-1 line-clamp-2">
              <%= result[:description] %>
            </p>
          <% end %>

          <!-- Result Metadata -->
          <div class="flex items-center gap-2 mt-2 text-xs text-ink-muted">
            <% if result[:owner].present? %>
              <span>👤 <%= result[:owner] %></span>
            <% end %>
            <% if result[:item_count].present? %>
              <span>📝 <%= result[:item_count] %> items</span>
            <% end %>
          </div>
        </a>
      <% end %>
    </div>
  <% else %>
    <!-- No Results State -->
    <div>
      <h4 class="t-eyebrow text-ink-subtle mb-2">No results found</h4>
      <p class="text-ink-muted">
        <% if search_data[:query].present? %>
          No items match your search for "<span class="font-semibold text-ink"><%= search_data[:query] %></span>"
        <% else %>
          Try searching for something
        <% end %>
      </p>
      <p class="text-xs text-ink-muted mt-2">Tip: Try a different term or use /browse to explore</p>
    </div>
  <% end %>
</div>
