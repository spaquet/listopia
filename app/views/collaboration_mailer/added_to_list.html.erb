<div class="email-header">
  <h1>You've been added to a list!</h1>
</div>

<div class="email-body">
  <p>Hi <%= @user.name %>,</p>
  <p><strong><%= @inviter.name %></strong> has added you as a collaborator to their list:</p>
  <div style="background-color: #f7f4ee; border: 1px solid #d9d2c1; border-radius: 4px; padding: 20px; margin: 20px 0;">
    <h2 style="margin: 0 0 10px 0; color: #13243a;"><%= @list.title %></h2>
    <% if @list.description.present? %>
      <p style="margin: 0; color: #666666;"><%= @list.description %></p>
    <% end %>
    <p style="margin: 10px 0 0 0; font-size: 14px; color: #666666;">
      Permission: <span style="font-weight: bold;"><%= @collaboration.permission.titleize %></span>
    </p>
  </div>
  <p>You can now:</p>
  <ul style="color: #13243a; line-height: 1.8;">
    <% if @collaboration.permission_collaborate? %>
      <li>View and edit list items</li>
      <li>Add new items to the list</li>
      <li>Mark items as complete</li>
      <li>Collaborate in real-time</li>
    <% else %>
      <li>View all list items</li>
      <li>See updates in real-time</li>
    <% end %>
  </ul>
  <div style="text-align: center;">
    <a href="<%= @list_url %>" class="button">View List</a>
  </div>
  <div class="divider"></div>
  <p style="font-size: 13px; color: #666666;">Happy organizing!<br><strong>The Listopia Team</strong></p>
</div>