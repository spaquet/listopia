<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">Calendar Conflicts</h1>
      <p class="text-gray-600">Upcoming scheduling conflicts in the next 14 days</p>
    </div>

    <% if @conflicts.any? %>
      <!-- Conflict count badge -->
      <div class="mb-6">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-red-50 border border-red-200 rounded-lg">
          <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
          <span class="font-semibold text-red-900"><%= @conflicts.count %> conflict<%= @conflicts.count > 1 ? 's' : '' %> found</span>
        </span>
      </div>

      <!-- Conflicts list -->
      <div class="space-y-4">
        <% @conflicts.each do |conflict| %>
          <% event = conflict[:event] %>
          <% overlapping = conflict[:overlapping_event] %>
          <div class="bg-white rounded-lg shadow-sm border-l-4 border-red-500 p-6">
            <!-- Conflict pair header -->
            <div class="mb-4 pb-4 border-b border-gray-200">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-lg font-semibold text-gray-900">Time Conflict</h3>
                <span class="text-sm text-red-600 font-medium">Overlapping</span>
              </div>
              <p class="text-sm text-gray-600">
                <%= event.start_time.strftime("%a, %b %d") %> at <%= event.start_time.strftime("%l:%M %p") %> — <%= event.end_time.strftime("%l:%M %p") %>
              </p>
            </div>

            <!-- Two event blocks side by side -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <!-- First event -->
              <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                <h4 class="font-semibold text-gray-900 mb-2"><%= event.summary %></h4>
                <div class="space-y-2 text-sm text-gray-600">
                  <p>
                    <span class="font-medium text-gray-700">Time:</span>
                    <%= event.start_time.strftime("%l:%M %p") %> — <%= event.end_time.strftime("%l:%M %p") %>
                  </p>
                  <% if event.organizer_name.present? %>
                    <p>
                      <span class="font-medium text-gray-700">Organizer:</span>
                      <%= event.organizer_name %>
                    </p>
                  <% end %>
                  <% if event.attendees.is_a?(Array) && event.attendees.any? %>
                    <p>
                      <span class="font-medium text-gray-700">Attendees:</span>
                      <%= event.attendees.count %>
                    </p>
                  <% end %>
                </div>
                <% if event.external_event_url.present? %>
                  <div class="mt-3">
                    <%= link_to "Open in Calendar", event.external_event_url, target: "_blank", rel: "noopener noreferrer",
                        class: "inline-flex items-center gap-1 text-sm text-blue-600 hover:text-blue-800 font-medium" %>
                  </div>
                <% end %>
              </div>

              <!-- Overlapping event -->
              <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                <h4 class="font-semibold text-gray-900 mb-2"><%= overlapping.summary %></h4>
                <div class="space-y-2 text-sm text-gray-600">
                  <p>
                    <span class="font-medium text-gray-700">Time:</span>
                    <%= overlapping.start_time.strftime("%l:%M %p") %> — <%= overlapping.end_time.strftime("%l:%M %p") %>
                  </p>
                  <% if overlapping.organizer_name.present? %>
                    <p>
                      <span class="font-medium text-gray-700">Organizer:</span>
                      <%= overlapping.organizer_name %>
                    </p>
                  <% end %>
                  <% if overlapping.attendees.is_a?(Array) && overlapping.attendees.any? %>
                    <p>
                      <span class="font-medium text-gray-700">Attendees:</span>
                      <%= overlapping.attendees.count %>
                    </p>
                  <% end %>
                </div>
                <% if overlapping.external_event_url.present? %>
                  <div class="mt-3">
                    <%= link_to "Open in Calendar", overlapping.external_event_url, target: "_blank", rel: "noopener noreferrer",
                        class: "inline-flex items-center gap-1 text-sm text-blue-600 hover:text-blue-800 font-medium" %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty state -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-green-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">No conflicts</h3>
        <p class="text-gray-600">Your schedule looks clear for the next 14 days!</p>
      </div>
    <% end %>
  </div>
</div>
