<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Integrations</h1>
      <p class="text-sm text-gray-600 mt-1">Connect third-party services to enhance your lists</p>
    </div>
  </div>

  <!-- Connected Accounts Section -->
  <% if @accounts.any? %>
    <div>
      <h2 class="text-lg font-medium text-gray-900 mb-4">Connected Accounts</h2>
      <div id="connected-accounts" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
        <% @accounts.each do |account| %>
          <%= turbo_frame_tag "connector_account_#{account.id}", class: "h-full" do %>
            <%= render "connectors/connector_accounts/account_card", account: account %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Available Services Section -->
  <div>
    <h2 class="text-lg font-medium text-gray-900 mb-4">Available Services</h2>
    <div id="available-services" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
      <% @connectors.each do |connector| %>
        <% connected = @accounts.any? { |a| a.provider == connector.key } %>
        <div class="group relative bg-white rounded-lg border border-gray-200 hover:border-blue-300 hover:shadow-sm transition-all duration-200 overflow-hidden flex flex-col h-full p-6">
          <!-- Connected badge -->
          <% if connected %>
            <div class="absolute top-3 right-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                Connected
              </span>
            </div>
          <% end %>

          <!-- Icon and Title -->
          <div class="flex items-start gap-4 mb-4">
            <div class="flex-shrink-0 text-gray-700">
              <%= icon_tag(connector.icon) %>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-medium text-gray-900 group-hover:text-blue-600 transition-colors duration-200">
                <%= connector.name %>
              </h3>
              <p class="text-xs text-gray-600 mt-0.5">
                <%= connector.category.titleize %>
              </p>
            </div>
          </div>

          <!-- Description -->
          <p class="text-gray-600 text-sm mb-6 flex-1 leading-relaxed">
            <%= connector.description %>
          </p>

          <!-- Action -->
          <div class="flex gap-2">
            <% if connected %>
              <%= link_to "Manage", "#", class: "flex-1 inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors duration-200" %>
            <% else %>
              <%= link_to "Connect", connectors_oauth_authorize_path(connector.key), class: "flex-1 inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors duration-200" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
