<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="t-display-s text-ink">Integrations</h1>
      <p class="text-sm text-ink-muted mt-1">Connect third-party services to enhance your lists</p>
    </div>
  </div>

  <!-- Connected Accounts Section -->
  <% if @accounts.any? %>
    <div>
      <h2 class="t-body-l text-ink mb-4">Connected Accounts</h2>
      <div id="connected-accounts" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
        <% @accounts.each do |account| %>
          <%= turbo_frame_tag "connector_account_#{account.id}", class: "h-full" do %>
            <%= render "connectors/connector_accounts/account_card", account: account %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Available Services Section -->
  <div>
    <h2 class="t-body-l text-ink mb-4">Available Services</h2>
    <div id="available-services" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
      <% @connectors.each do |connector| %>
        <% connected = @accounts.any? { |a| a.provider == connector.key } %>
        <div class="connector-card">
          <!-- Connected badge -->
          <% if connected %>
            <div class="connector-card-badge">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              Connected
            </div>
          <% end %>

          <!-- Icon and Title -->
          <div class="connector-card-header">
            <div class="connector-card-icon">
              <%= icon_tag(connector.icon) %>
            </div>
            <div class="connector-card-info flex-1">
              <h3><%= connector.name %></h3>
              <p><%= connector.category.titleize %></p>
            </div>
          </div>

          <!-- Description -->
          <p class="connector-card-description">
            <%= connector.description %>
          </p>

          <!-- Action -->
          <% if connected %>
            <%= link_to "Manage", "#", class: "connector-card-action-button" %>
          <% else %>
            <%= link_to "Connect", connectors_oauth_authorize_path(connector.key), class: "connector-card-action-button primary" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
