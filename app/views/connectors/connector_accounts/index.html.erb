<div class="container mx-auto max-w-4xl px-4 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">My Connections</h1>
    <p class="text-gray-600 dark:text-gray-400">Connect third-party services to enhance your lists</p>
  </div>

  <% if @accounts.any? %>
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Connected Accounts</h2>
      <div class="bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-800 overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
            <tr>
              <th class="text-left px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-300">Provider</th>
              <th class="text-left px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-300">Account</th>
              <th class="text-left px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-300">Status</th>
              <th class="text-right px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-300">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            <% @accounts.each do |account| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
                <td class="px-6 py-3">
                  <span class="font-medium text-gray-900 dark:text-white"><%= account.provider.titleize %></span>
                </td>
                <td class="px-6 py-3 text-gray-600 dark:text-gray-400">
                  <% if account.display_name.present? %>
                    <%= account.display_name %>
                  <% elsif account.email.present? %>
                    <%= account.email %>
                  <% else %>
                    <%= account.provider_uid %>
                  <% end %>
                </td>
                <td class="px-6 py-3">
                  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold
                    <% case account.status %>
                    <% when 'active' %>
                      bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200
                    <% when 'paused' %>
                      bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200
                    <% when 'errored' %>
                      bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200
                    <% else %>
                      bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300
                    <% end %>
                  ">
                    <%= account.status.titleize %>
                  </span>
                </td>
                <td class="px-6 py-3 text-right">
                  <div class="flex gap-2 justify-end">
                    <%= link_to "Settings", connectors_setting_path(account), class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 text-sm font-medium" %>
                    <% if account.active? %>
                      <%= link_to "Pause", connectors_pause_connector_account_path(account), method: :patch, class: "text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300 text-sm font-medium" %>
                    <% elsif account.paused? %>
                      <%= link_to "Resume", connectors_resume_connector_account_path(account), method: :patch, class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 text-sm font-medium" %>
                    <% end %>
                    <%= link_to "Disconnect", connectors_connector_account_path(account), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300 text-sm font-medium" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <div>
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Available Services</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% @connectors.each do |connector| %>
        <% connected = @accounts.any? { |a| a.provider == connector.key } %>
        <div class="bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-800 p-6 hover:border-gray-300 dark:hover:border-gray-700 transition">
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-start gap-4">
              <div class="text-3xl">
                <%= icon_tag(connector.icon, class: "w-8 h-8") %>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= connector.name %></h3>
                <p class="text-sm text-gray-600 dark:text-gray-400"><%= connector.category.titleize %></p>
              </div>
            </div>
            <% if connected %>
              <span class="inline-block px-2 py-1 bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 rounded text-xs font-semibold">Connected</span>
            <% end %>
          </div>
          <p class="text-gray-600 dark:text-gray-400 text-sm mb-4"><%= connector.description %></p>
          <% unless connected %>
            <%= link_to "Connect", connectors_oauth_authorize_path(connector.key), class: "inline-block px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 text-sm font-medium transition" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
