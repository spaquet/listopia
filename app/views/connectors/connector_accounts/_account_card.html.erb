<%# app/views/connectors/connector_accounts/_account_card.html.erb %>
<div id="account_card_<%= account.id %>" class="group relative bg-white rounded-lg border border-gray-200 hover:border-blue-300 hover:shadow-sm transition-all duration-200 overflow-hidden flex flex-col h-full">

  <!-- Quick Actions (icons only, on hover) -->
  <div class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center space-x-1 z-10">
    <!-- Settings -->
    <%= link_to connectors_setting_path(account),
              class: "p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded transition-all duration-200",
              title: "Settings" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
    <% end %>

    <!-- Pause/Resume -->
    <% if account.active? %>
      <%= button_to connectors_pause_connector_account_path(account),
                    method: :patch,
                    class: "p-1.5 text-gray-400 hover:text-yellow-600 hover:bg-yellow-50 rounded transition-all duration-200",
                    title: "Pause" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      <% end %>
    <% elsif account.paused? %>
      <%= button_to connectors_resume_connector_account_path(account),
                    method: :patch,
                    class: "p-1.5 text-gray-400 hover:text-green-600 hover:bg-green-50 rounded transition-all duration-200",
                    title: "Resume" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      <% end %>
    <% end %>

    <!-- Disconnect -->
    <%= button_to connectors_connector_account_path(account),
                  method: :delete,
                  data: {
                    turbo_stream: true,
                    turbo_confirm: "Are you sure you want to disconnect this account?"
                  },
                  class: "p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded transition-all duration-200",
                  title: "Disconnect" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    <% end %>
  </div>

  <!-- Clickable card content -->
  <div class="flex flex-col flex-1 px-6 py-6">
    <!-- Status badge -->
    <div class="mb-4 shrink-0">
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
        <% case account.status %>
        <% when 'active' %>
          bg-green-100 text-green-800
        <% when 'paused' %>
          bg-yellow-100 text-yellow-800
        <% when 'errored' %>
          bg-red-100 text-red-800
        <% else %>
          bg-gray-100 text-gray-800
        <% end %>
      ">
        <%= account.status.titleize %>
      </span>
    </div>

    <!-- Provider and Account Info -->
    <div class="mb-4 shrink-0">
      <h3 class="text-base font-medium text-gray-900 group-hover:text-blue-600 transition-colors duration-200">
        <%= account.provider.titleize %>
      </h3>
      <p class="mt-1 text-sm text-gray-600">
        <% if account.display_name.present? %>
          <%= account.display_name %>
        <% elsif account.email.present? %>
          <%= account.email %>
        <% else %>
          <%= account.provider_uid %>
        <% end %>
      </p>
    </div>

    <!-- Connected since -->
    <div class="text-xs text-gray-500 shrink-0">
      Connected <%= time_ago_in_words(account.created_at) %> ago
    </div>
  </div>
</div>
