<div class="container mx-auto max-w-6xl px-4 py-8">
  <div class="mb-8">
    <h1 class="t-display-m text-ink">Google Drive Files</h1>
    <p class="text-ink-muted mt-1 t-body">Browse and attach files from your Google Drive</p>
  </div>

  <!-- Search form -->
  <div class="mb-6">
    <form method="get" action="<%= connectors_storage_google_drive_files_path %>" class="flex gap-2">
      <%= hidden_field_tag :connector_account_id, @connector_account.id %>
      <%= text_field_tag :q, @query, placeholder: "Search files...", class: "form-input flex-1" %>
      <button type="submit" class="btn btn-primary">
        Search
      </button>
    </form>
  </div>

  <!-- Files list -->
  <div class="bg-surface-raised rounded-md border border-rule overflow-hidden">
    <% if @files.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y border-rule">
          <thead class="bg-surface-sunken border-b border-rule">
            <tr>
              <th class="px-6 py-3 text-left t-eyebrow text-ink-subtle">Name</th>
              <th class="px-6 py-3 text-left t-eyebrow text-ink-subtle">Type</th>
              <th class="px-6 py-3 text-left t-eyebrow text-ink-subtle">Size</th>
              <th class="px-6 py-3 text-left t-eyebrow text-ink-subtle">Modified</th>
              <th class="px-6 py-3 text-left t-eyebrow text-ink-subtle">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y border-rule">
            <% @files.each do |file| %>
              <tr class="hover:bg-surface-raised transition-colors duration-fast">
                <td class="px-6 py-4 whitespace-nowrap t-body">
                  <div class="flex items-center gap-2">
                    <% case file["mimeType"]
                       when /google/
                         icon = "📄"
                       when /spreadsheet/
                         icon = "📊"
                       when /presentation/
                         icon = "📽️"
                       when /folder/
                         icon = "📁"
                       when /pdf/
                         icon = "📕"
                       when /image/
                         icon = "🖼️"
                       else
                         icon = "📎"
                       end %>
                    <span class="text-lg"><%= icon %></span>
                    <span class="font-medium text-ink"><%= file["name"] %></span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap t-body text-ink-muted">
                  <span class="px-2 py-1 bg-surface-sunken text-ink rounded-sm text-xs">
                    <%= file["mimeType"].split("/").last.capitalize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap t-body text-ink-muted">
                  <% if file["size"].present? %>
                    <%= number_to_human_size(file["size"]) %>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap t-body text-ink-muted">
                  <% if file["modifiedTime"].present? %>
                    <%= time_ago_in_words(Time.parse(file["modifiedTime"])) %> ago
                  <% else %>
                    -
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap t-body flex gap-2">
                  <% if file["webViewLink"].present? %>
                    <%= link_to "Open", file["webViewLink"], target: "_blank", class: "text-accent hover:text-accent transition-colors duration-fast" %>
                  <% end %>
                  <%= link_to "View", connectors_storage_google_drive_file_path(@connector_account.id, file["id"]), class: "text-accent hover:text-accent transition-colors duration-fast" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @next_page_token.present? %>
        <div class="px-6 py-4 border-t border-rule flex justify-center">
          <%= form_with local: true, method: :get, url: connectors_storage_google_drive_files_path, class: "flex gap-2" do %>
            <%= hidden_field_tag :connector_account_id, @connector_account.id %>
            <%= hidden_field_tag :q, @query %>
            <%= hidden_field_tag :page_token, @next_page_token %>
            <button type="submit" class="btn btn-primary">
              Load More
            </button>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="p-8 text-center">
        <p class="text-ink-muted mb-4 t-body">
          <% if @query.present? %>
            No files found matching "<%= @query %>". Try a different search.
          <% else %>
            Your Google Drive is empty or we couldn't access it.
          <% end %>
        </p>
        <%= link_to "Back", connectors_connector_accounts_path, class: "text-accent hover:text-accent transition-colors duration-fast" %>
      </div>
    <% end %>
  </div>
</div>
