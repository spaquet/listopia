<div class="container mx-auto max-w-6xl px-4 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Google Drive Files</h1>
    <p class="text-gray-600 dark:text-gray-400">Browse and attach files from your Google Drive</p>
  </div>

  <!-- Search form -->
  <div class="mb-6">
    <form method="get" action="<%= connectors_storage_google_drive_files_path %>" class="flex gap-2">
      <%= hidden_field_tag :connector_account_id, @connector_account.id %>
      <%= text_field_tag :q, @query, placeholder: "Search files...", class: "flex-1 px-4 py-2 border border-gray-300 rounded-lg dark:border-gray-700 dark:bg-gray-800 dark:text-white" %>
      <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 font-medium">
        Search
      </button>
    </form>
  </div>

  <!-- Files list -->
  <div class="bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-800 overflow-hidden">
    <% if @files.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-800">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Size</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Modified</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            <% @files.each do |file| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <div class="flex items-center gap-2">
                    <% case file["mimeType"]
                       when /google/
                         icon = "📄"
                       when /spreadsheet/
                         icon = "📊"
                       when /presentation/
                         icon = "📽️"
                       when /folder/
                         icon = "📁"
                       when /pdf/
                         icon = "📕"
                       when /image/
                         icon = "🖼️"
                       else
                         icon = "📎"
                       end %>
                    <span class="text-lg"><%= icon %></span>
                    <span class="font-medium text-gray-900 dark:text-white"><%= file["name"] %></span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                  <span class="px-2 py-1 bg-gray-100 dark:bg-gray-800 rounded text-xs">
                    <%= file["mimeType"].split("/").last.capitalize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                  <% if file["size"].present? %>
                    <%= number_to_human_size(file["size"]) %>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
                  <% if file["modifiedTime"].present? %>
                    <%= time_ago_in_words(Time.parse(file["modifiedTime"])) %> ago
                  <% else %>
                    -
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm flex gap-2">
                  <% if file["webViewLink"].present? %>
                    <%= link_to "Open", file["webViewLink"], target: "_blank", class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300" %>
                  <% end %>
                  <%= link_to "View", connectors_storage_google_drive_file_path(@connector_account.id, file["id"]), class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @next_page_token.present? %>
        <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 flex justify-center">
          <%= form_with local: true, method: :get, url: connectors_storage_google_drive_files_path, class: "flex gap-2" do %>
            <%= hidden_field_tag :connector_account_id, @connector_account.id %>
            <%= hidden_field_tag :q, @query %>
            <%= hidden_field_tag :page_token, @next_page_token %>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 font-medium">
              Load More
            </button>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="p-8 text-center">
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          <% if @query.present? %>
            No files found matching "<%= @query %>". Try a different search.
          <% else %>
            Your Google Drive is empty or we couldn't access it.
          <% end %>
        </p>
        <%= link_to "Back", connectors_connector_accounts_path, class: "text-blue-600 hover:text-blue-800 dark:text-blue-400" %>
      </div>
    <% end %>
  </div>
</div>
