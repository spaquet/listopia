<div class="container mx-auto max-w-4xl px-4 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Select Slack Channel</h1>
    <p class="text-gray-600 dark:text-gray-400">Choose the default channel for posting Listopia updates</p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-800 overflow-hidden">
    <% if @channels.any? %>
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @channels.each do |channel| %>
          <div class="p-6 hover:bg-gray-50 dark:hover:bg-gray-800 transition">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white">#<%= channel["name"] %></h3>
                  <% if channel["is_private"] %>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                      🔒 Private
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                      🌐 Public
                    </span>
                  <% end %>
                </div>
                <p class="text-xs text-gray-500 dark:text-gray-500">ID: <%= channel["id"] %></p>
              </div>
              <form method="post" action="<%= connectors_messaging_slack_channels_select_path %>">
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                <%= hidden_field_tag :connector_account_id, @connector_account.id %>
                <%= hidden_field_tag :channel_id, channel["id"] %>
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 font-medium">
                  Select
                </button>
              </form>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-8 text-center">
        <p class="text-gray-600 dark:text-gray-400 mb-4">No channels found. Make sure you have channels in your Slack workspace.</p>
        <%= link_to "Back", connectors_setting_path(@connector_account), class: "text-blue-600 hover:text-blue-800 dark:text-blue-400" %>
      </div>
    <% end %>
  </div>
</div>
