<button class="theme-toggle p-2 rounded-md border border-rule hover:bg-surface-raised transition-colors duration-base"
        data-action="theme#toggle"
        title="Toggle theme (Editorial/Console)">
  <svg class="w-5 h-5 text-ink" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <!-- Sun icon for light theme -->
    <circle cx="12" cy="12" r="5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></circle>
    <line x1="12" y1="1" x2="12" y2="3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></line>
    <line x1="12" y1="21" x2="12" y2="23" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></line>
    <line x1="1" y1="12" x2="3" y2="12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></line>
    <line x1="21" y1="12" x2="23" y2="12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun"></line>

    <!-- Moon icon for dark theme -->
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-moon hidden"></path>
  </svg>
</button>

<style>
  [data-theme="editorial"] .theme-icon-sun {
    opacity: 1;
  }
  [data-theme="editorial"] .theme-icon-moon {
    display: none;
  }

  [data-theme="console"] .theme-icon-sun {
    opacity: 0;
  }
  [data-theme="console"] .theme-icon-moon {
    display: block;
  }
</style>
