<!-- app/views/shared/_chat_message.html.erb
     Unified chat message rendering with template support
     Handles both regular markdown messages and templated messages
-->

<div class="chat-message <%= message.role %> <%= message.system_message? ? 'mb-2' : 'mb-3' %>"
     data-message-id="<%= message.id %>"
     id="message-<%= message.id %>">

  <div class="flex <%= message.user_message? ? 'justify-end' : 'justify-start' %>">
    <!-- Message Container -->
    <div class="<%= message_bubble_classes(message) %>">
      <!-- Message Content -->
      <% if message.template_type.present? %>
        <!-- Render template if present -->
        <%= render "message_templates/#{message.template_type}",
                   data: message.metadata["template_data"],
                   message: message %>
      <% else %>
        <!-- Fall back to markdown rendering -->
        <div class="message-content <%= message.system_message? ? 'text-xs' : 'prose prose-sm max-w-none text-xs' %>">
          <% if message.user_message? %>
            <!-- User message with command formatting -->
            <% if message.content.start_with?("/") %>
              <!-- Format command messages: bold command part -->
              <% parts = message.content.split(" ", 2) %>
              <strong><%= parts[0] %></strong><% if parts[1].present? %> <%= parts[1] %><% end %>
            <% elsif has_mentions?(message) || has_references?(message) %>
              <%= render_message_with_mentions(message) %>
            <% else %>
              <%= render_markdown(message.content) %>
            <% end %>
          <% else %>
            <%= render_markdown(message.content) %>
          <% end %>
        </div>
      <% end %>

      <!-- RAG Sources (if present) -->
      <% if message.metadata["rag_sources"].present? && message.assistant_message? %>
        <div class="mt-3 pt-3 border-t border-gray-300 border-opacity-30">
          <%= render "message_templates/rag_sources",
                     sources: message.metadata["rag_sources"] %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Message Footer (Timestamp and Rating) -->
  <% if message.user_message? %>
    <div class="flex justify-end mt-1 text-xs text-ink-muted pr-2">
      <span><%= time_ago_in_words(message.created_at) %> ago</span>
    </div>
  <% elsif message.assistant_message? %>
    <div class="flex justify-start mt-2 text-xs text-ink-muted">
      <div class="ml-2 flex items-center gap-2">
        <!-- Timestamp -->
        <span><%= time_ago_in_words(message.created_at) %> ago</span>

        <!-- Message Rating Buttons -->
        <div class="flex items-center gap-2 border-l border-rule pl-2"
             data-controller="message-rating"
             data-message-id="<%= message.id %>"
             data-chat-id="<%= chat_context&.chat&.id %>">

          <button class="text-ink-muted hover:text-accent hover:bg-surface-raised transition-colors p-1 rounded-sm duration-fast"
                  data-action="message-rating#rate"
                  data-rating="helpful"
                  title="Helpful"
                  aria-label="Mark as helpful">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
            </svg>
          </button>

          <button class="text-ink-muted hover:text-accent hover:bg-surface-raised transition-colors p-1 rounded-sm duration-fast"
                  data-action="message-rating#rate"
                  data-rating="unhelpful"
                  title="Not helpful"
                  aria-label="Mark as not helpful">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <!-- Report -->
          <button class="text-ink-muted hover:text-accent hover:bg-surface-raised transition-colors p-1 rounded-sm duration-fast"
                  data-action="click->message-rating#showReportModal"
                  title="Report"
                  aria-label="Report message">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  <% end %>
</div>

<style>
  /* Message bubble styling based on role */
  .chat-message.user {
    --message-bg: var(--color-accent-soft);
    --message-text: var(--color-ink-inverse);
  }

  .chat-message.assistant {
    --message-bg: var(--color-surface-raised);
    --message-text: var(--color-ink);
  }

  .chat-message.system {
    --message-bg: var(--color-surface-sunken);
    --message-text: var(--color-ink-muted);
  }

  .chat-message .message-content {
    color: var(--message-text);
    background: var(--message-bg);
    padding: 0.75rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    line-height: 1.5;
    max-width: 28rem;
  }

  /* Code block styling inside messages */
  .message-content pre {
    background: var(--color-surface-sunken);
    color: var(--color-ink);
    padding: 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    overflow-x: auto;
    margin: 0.5rem 0;
  }

  .message-content code {
    background: var(--color-surface-sunken);
    color: var(--color-accent);
    padding: 0.25rem 0.375rem;
    border-radius: var(--radius-xs);
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .message-content pre code {
    background: transparent;
    color: var(--color-ink);
    padding: 0;
  }

  /* Link styling */
  .message-content a {
    color: var(--color-accent);
    text-decoration: underline;
    transition: opacity var(--duration-fast);
  }

  .message-content a:hover {
    opacity: 0.8;
  }

  /* List styling */
  .message-content ul,
  .message-content ol {
    margin-left: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .message-content li {
    margin: 0.25rem 0;
  }

  /* Table styling */
  .message-content table {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.875rem;
    margin: 0.5rem 0;
  }

  .message-content th,
  .message-content td {
    border: 1px solid var(--color-rule);
    padding: 0.5rem;
  }

  .message-content th {
    background: var(--color-surface-sunken);
    font-weight: 600;
    color: var(--color-ink);
  }

  /* Blockquote styling */
  .message-content blockquote {
    border-left: 3px solid var(--color-rule);
    padding-left: 1rem;
    margin: 0.5rem 0;
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
