<!-- app/views/shared/_organization_switcher_modal.html.erb -->
<div class="modal-backdrop" aria-labelledby="org-switcher-title" role="dialog" aria-modal="true">
  <div class="modal-content w-full max-w-2xl">
    <!-- Header -->
    <div class="modal-header">
      <div>
        <h3 id="org-switcher-title">Select Organization</h3>
        <p class="text-sm text-ink-muted mt-1">Switch between your organizations</p>
      </div>
      <button type="button" class="modal-close" data-action="click->modal#close">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Organization List -->
    <div class="modal-body max-h-96 overflow-y-auto">
      <% if @organizations.any? %>
        <div class="space-y-3">
          <% @organizations.each do |org| %>
            <% membership = current_user.organization_membership(org) %>
            <% role = membership&.role %>
            <% is_current = current_organization && current_organization.id == org.id %>
            <!-- Organization Card -->
            <%= form_with url: switch_organizations_path, method: :patch, local: true, class: "group" do |f| %>
              <%= f.hidden_field :organization_id, value: org.id %>
              <button type="submit" class="w-full flex items-stretch gap-4 p-4 rounded-lg border transition-all duration-200 cursor-pointer
                             #{is_current ? 'border-accent bg-accent-soft' : 'border-rule bg-surface hover:border-accent hover:bg-surface-raised'}">
                <!-- Avatar -->
                <div class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center shrink-0 text-ink-inverse font-bold text-sm">
                  <%= org.name.first.upcase %>
                </div>
                <!-- Text Info -->
                <div class="flex-1 min-w-0 flex flex-col justify-center items-start">
                  <h4 class="text-sm font-semibold text-ink truncate"><%= org.name %></h4>
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-xs text-ink-muted"><%= org.size.titleize %></span>
                    <% if role %>
                      <span class="pill <%= role == 'owner' ? 'accent' : role == 'admin' ? 'warning' : '' %>">
                        <%= role.titleize %>
                      </span>
                    <% end %>
                    <% if is_current %>
                      <span class="pill success">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                        Active
                      </span>
                    <% end %>
                  </div>
                </div>
              </button>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-ink-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4l2-3h2l2 3h4a2 2 0 012 2v14a2 2 0 01-2 2z"></path>
          </svg>
          <p class="mt-4 text-sm font-medium text-ink">No active organizations</p>
          <p class="mt-2 text-sm text-ink-muted">You don't have any active organizations</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
